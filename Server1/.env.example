# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/server1
DATABASE_SSL_ENABLED=false

# JWT (RS256 PEM values can use escaped \n)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=90d

# Email (password reset + verification) — OCI Email Delivery (HTTPS data-plane API)
FROM_EMAIL=no-reply@example.com
OCI_TENANCY_ID=
OCI_USER_ID=
OCI_FINGERPRINT=
OCI_PRIVATE_KEY=
OCI_PRIVATE_KEY_PASSPHRASE=
OCI_REGION=us-chicago-1
OCI_EMAIL_COMPARTMENT_ID=

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Google Sign-In
# Accepts one or more client IDs, comma-separated, matching the audiences
# used by iOS / Android / Web Google sign-in flows.
GOOGLE_CLIENT_ID=ios-client-id.apps.googleusercontent.com,android-client-id.apps.googleusercontent.com,web-client-id.apps.googleusercontent.com

# Sign in with Apple
# Expected audience ('aud' claim) on the identity token from the native flow —
# this is your app's bundle id. Optional: falls back to APNS_BUNDLE_ID below if unset.
APPLE_BUNDLE_ID=

# User file storage (Supabase Storage). One bucket holds everything; categories
# (avatars, covers, …) are key prefixes within it, not separate buckets.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=user-content
SUPABASE_STORAGE_PUBLIC_URL=


# Encryption for external tokens at rest
ENCRYPTION_KEY=

# Push providers
APNS_BUNDLE_ID=
FCM_SERVICE_ACCOUNT_PATH=

# Reminders — Phase 3B
INTERNAL_REMINDER_SECRET=
REMINDER_FIRE_BATCH_SIZE=100
REMINDER_AGENT_EVENT_TIMEOUT_MS=2000
