# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/server1
DATABASE_SSL_ENABLED=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=
REDIS_PORT=16379
REDIS_USERNAME=default
REDIS_PASSWORD=YOUR_NEW_ROTATED_PASSWORD
REDIS_TLS_ENABLED=false


# JWT (RS256 PEM values can use escaped \n)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=90d
PASSWORD_RESET_URL=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=no-reply@example.com

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Google Sign-In
# Accepts one or more client IDs, comma-separated, matching the audiences
# used by iOS / Android / Web Google sign-in flows.
GOOGLE_CLIENT_ID=ios-client-id.apps.googleusercontent.com,android-client-id.apps.googleusercontent.com,web-client-id.apps.googleusercontent.com

# Avatar storage (Supabase Storage)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=avatars
SUPABASE_STORAGE_PUBLIC_URL=


# Encryption for external tokens at rest
ENCRYPTION_KEY=

# Push providers
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=
APNS_BUNDLE_ID=
FCM_SERVICE_ACCOUNT_PATH=

# Integration providers
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=
MICROSOFT_TENANT_ID=
