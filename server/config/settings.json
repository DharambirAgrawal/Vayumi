{
  "server": {
    "host": "0.0.0.0",
    "port": 8000,
    "debug": true
  },
  "database": {
    "sqlite_path": "data/vayumi.db",
    "vectordb_path": "data/vectordb"
  },
  "tts": {
    "model_path": "kokoro-v0_19.onnx",
    "voices_path": "voices.bin",
    "default_voice": "af",
    "default_speed": 1.0
  },
  "vad": {
    "normal_threshold": 0.5,
    "echo_threshold": 0.8,
    "min_sustained_ms": 300
  },
  "diarizer": {
    "model_source": "speechbrain/spkrec-ecapa-voxceleb",
    "model_cache_dir": "models/speaker_encoder",
    "recognition_threshold": 0.75
  },
  "embedder": {
    "model_name": "all-MiniLM-L6-v2"
  },
  "session": {
    "active_window_timeout_seconds": 30,
    "reconnect_grace_period_seconds": 60
  },
  "rate_limits": {
    "max_rpm_per_user": 10,
    "max_tpm_per_user": 50000
  },
  "memory": {
    "summarize_every_n_turns": 15,
    "max_retrieved_memories": 5
  },
  "skills": {
    "execution_timeout_seconds": 30,
    "registry_path": "server/skills/skill_registry.json"
  },
  "mcps": {
    "registry_path": "server/mcps/mcp_registry.json"
  }
}
