# =============================================================================
# Vayumi server — environment variables
# =============================================================================
# Copy to server/.env and fill in values (keep server/.env out of git).
#
# Loading: either export these in your shell before uvicorn, or add
# python-dotenv in server/main.py to load Path(__file__).parent / ".env".
# =============================================================================

# --- Required API keys ---
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- Auth ---
# Change in production; used to sign JWTs.
VAYUMI_JWT_SECRET=change-me-to-a-random-secret-in-production
