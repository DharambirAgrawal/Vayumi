# Vayumi server runtime configuration

# ------------------------------
# Core server
# ------------------------------
HOST=0.0.0.0
PORT=8000
SESSION_TIMEOUT_SECONDS=60

# ------------------------------
# Authentication / API
# ------------------------------
# Required for auth bootstrap.
DATABASE_URL=postgresql://user:pass@localhost:5432/vayumi
# Optional fallback used by config loader.
NEON_API_KEY=

JWT_SECRET=change_me_for_prod
JWT_ALGORITHM=HS256
JWT_TTL_SECONDS=604800

# ------------------------------
# Main agent / local LLM
# ------------------------------
# Used by AgentRunner as model hint.
AGENT_MODEL=gpt-3.5-turbo

# Used by orchestrator LiteRT worker discovery.
LITERT_MODEL_PATH=
# Optional override for LiteRT cache directory.
# If empty, cache defaults to <selected_model_dir>/.litert_cache.
LITERT_CACHE_DIR=

# ------------------------------
# STT
# ------------------------------
STT_PROVIDER=whisper
STT_MODEL=whisper-large-v3
STT_LANGUAGE=en
STT_PROMPT=Wake word is Vayumi. Possible spellings: Vayumi, Wayumi, Vai Umi, Vaiyumi.
STT_REQUEST_TIMEOUT_SECONDS=30.0

# Groq-backed STT (if enabled by provider implementation)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ------------------------------
# TTS
# ------------------------------
TTS_PROVIDER=kokoro_onnx
KOKORO_VOICE=af_heart
TTS_FALLBACK_VOICE=Samantha
TTS_ALLOW_SYSTEM_FALLBACK=false
KOKORO_MODEL_PATH=./models/tts/kokoro-v1.0.onnx
KOKORO_VOICES_PATH=./models/tts/voices-v1.0.bin
KOKORO_SPEED=1.0

# ------------------------------
# VAD / wake / interruption tuning
# ------------------------------
VAD_SILENCE_DURATION_MS=320
VAD_RMS_THRESHOLD=0.05
MIN_TRANSCRIBE_SEGMENT_MS=1200
MEETING_MIN_TRANSCRIBE_SEGMENT_MS=6000
AGENT_CHUNK_DELAY_MS=20

WAKE_COMMAND_WINDOW_SECONDS=8
WAKE_SINGLE_COMMAND_MODE=true
MIN_COMMAND_GAP_SECONDS=1.2
SELF_ECHO_SUPPRESSION_SECONDS=2.0
WAKE_INTERRUPT_MIN_CONFIDENCE=0.78
LIVE_INTERRUPT_CHECK_MS=400
LIVE_INTERRUPT_BUFFER_MS=900

WAKE_DETECTOR_PROVIDER=local_whisper
WAKE_DETECTOR_THRESHOLD=0.45
WAKE_DETECTOR_MODEL_PATH=
WAKE_WORD_NAME=vayumi
WAKE_DETECTOR_WHISPER_MODEL=tiny.en
WAKE_DETECTOR_WHISPER_LANGUAGE=en

# ------------------------------
# Speaker / diarization
# ------------------------------
OWNER_VOICE_THRESHOLD=0.75
DIARIZATION_PROVIDER=pyannote

# ------------------------------
# Memory integration
# ------------------------------
MEMORY_DB_PATH=./data/memory/memory.db
MEMORY_BLOB_DIR=./data/memory/blobs
MEMORY_COLLECTION=memories
MEMORY_PROVIDER_MODE=auto
