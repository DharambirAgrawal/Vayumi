        <mxCell id="vm3" value="focus" style="fontSize=8;" edge="1" parent="1" source="v_mode_check" target="v_focus"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- OUTPUT PATH -->
        <mxCell id="v_orch" value="CENTRAL&#xa;CONSCIOUSNESS&#xa;(Orchestrator)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
