        <mxCell id="vo3" value="complete&#xa;sentences" style="rounded=1;strokeWidth=2;strokeColor=#82b366;fontSize=8;" edge="1" parent="1" source="v_sentence" target="v_tts"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Final output -->
        <mxCell id="v_ws_out" value="[8] WebSocket&#xa;Audio Stream&#xa;playback_state=PLAYING" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
