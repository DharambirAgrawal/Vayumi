        </mxCell>
        <mxCell id="v_add_ctx" value="Pause TTS&#xa;Add Context&#xa;→ INTERRUPTED" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
