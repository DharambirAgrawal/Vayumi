        <mxCell id="vo5" style="rounded=1;strokeWidth=2;strokeColor=#d6b656;" edge="1" parent="1" source="v_ws_out" target="v_speaker"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="vo6" value="done playing" style="rounded=1;strokeWidth=1;strokeColor=#82b366;dashed=1;fontSize=8;" edge="1" parent="1" source="v_speaker" target="v_playback_done"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Echo feedback loop annotation -->
        <mxCell id="v_echo_loop" value="Echo feedback loop (prevented):&#xa;Speaker plays audio → Mic picks up → AEC subtracts speaker ref → Clean audio only&#xa;&#xa;ESP32: Hardware AEC (primary) — server never hears Vayumi's voice&#xa;Browser: Web Audio API + server-side gating (raised VAD threshold during PLAYING)" style="text;fontSize=10;align=left;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="810" width="500" height="80" as="geometry" />
        </mxCell>

        <!-- Latency note -->
        <mxCell id="v_latency" value="Total latency target: ~500ms from user stops speaking to Vayumi starts speaking&#xa;Key: TTS starts on FIRST complete sentence while LLM is still generating the rest" style="text;fontSize=10;align=left;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="920" width="500" height="50" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
