          <mxGeometry x="700" y="110" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="v_web_aec" value="Web Audio API&#xa;echoCancellation:true&#xa;(basic suppression)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="910" y="110" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="v_browser_audio" value="Partially Clean&#xa;Audio (echo&#xa;residue possible)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1130" y="110" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="va_b1" style="rounded=1;strokeWidth=2;strokeColor=#d6b656;" edge="1" parent="1" source="v_mic_browser" target="v_web_aec"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="va_b2" style="rounded=1;strokeWidth=2;strokeColor=#d6b656;" edge="1" parent="1" source="v_web_aec" target="v_browser_audio"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Both paths converge to WebSocket -->
