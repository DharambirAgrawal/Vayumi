        <mxCell id="vo1" value="streaming&#xa;tokens" style="rounded=1;strokeWidth=2;strokeColor=#9673a6;fontSize=8;" edge="1" parent="1" source="v_orch" target="v_llm"><mxGeometry relative="1" as="geometry" /></mxCell>
