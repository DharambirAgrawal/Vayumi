          <mxGeometry x="640" y="580" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="v_meeting" value="Meeting Mode&#xa;→ Log + selective response" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="820" y="580" width="160" height="50" as="geometry" />
