          <mxGeometry x="1050" y="280" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="va3" value="speech&#xa;segments" style="rounded=1;strokeWidth=2;strokeColor=#6c8ebf;fontSize=8;" edge="1" parent="1" source="v_vad" target="v_stt"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="va4" value="text +&#xa;audio" style="rounded=1;strokeWidth=2;strokeColor=#6c8ebf;fontSize=8;" edge="1" parent="1" source="v_stt" target="v_diarize"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="va5" style="rounded=1;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" parent="1" source="v_diarize" target="v_parsed"><mxGeometry relative="1" as="geometry" /></mxCell>

