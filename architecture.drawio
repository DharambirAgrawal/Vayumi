          <mxGeometry x="250" y="280" width="130" height="60" as="geometry" />
        </mxCell>

        <mxCell id="va_esp_ws" value="echo-cancelled" style="rounded=1;strokeWidth=2;strokeColor=#82b366;fontSize=8;" edge="1" parent="1" source="v_clean_audio" target="v_ws_in">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="540" y="250" /><mxPoint x="315" y="250" /></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="va_br_ws" value="partially cleaned" style="rounded=1;strokeWidth=2;strokeColor=#d6b656;fontSize=8;" edge="1" parent="1" source="v_browser_audio" target="v_ws_in">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="1205" y="250" /><mxPoint x="315" y="250" /></Array>
          </mxGeometry>
        </mxCell>

        <!-- Server-side echo gating -->
        <mxCell id="v_vad" value="[1] VAD&#xa;(Echo-Aware)&#xa;Checks playback_state" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="280" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="v_echo_gate" value="playback_state&#xa;= PLAYING?&#xa;→ Raised threshold&#xa;→ Min 300ms duration" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="360" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="va_ws_vad" value="audio chunks" style="rounded=1;strokeWidth=2;strokeColor=#6c8ebf;fontSize=8;" edge="1" parent="1" source="v_ws_in" target="v_vad"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="va_gate" value="echo gating" style="rounded=1;strokeWidth=1;strokeColor=#b85450;dashed=1;fontSize=8;" edge="1" parent="1" source="v_echo_gate" target="v_vad"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Rest of pipeline -->
        <mxCell id="v_stt" value="[2] Groq Whisper&#xa;STT&#xa;(speech → text)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="280" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="v_diarize" value="[3] Diarizer&#xa;Speaker ID&#xa;(ECAPA-TDNN embeddings)" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
