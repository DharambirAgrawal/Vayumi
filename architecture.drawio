          <mxGeometry x="1050" y="920" width="130" height="50" as="geometry" />
        </mxCell>
        <mxCell id="v_playback_done" value="Client sends&#xa;playback_done&#xa;→ playback_state=IDLE&#xa;→ ACTIVE" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="830" y="920" width="160" height="60" as="geometry" />
