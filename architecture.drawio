          <mxGeometry x="270" y="230" width="170" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ub_files" value="Files B&#xa;/var/vayumi/files/user_ananya/" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="user_b_group">
          <mxGeometry x="270" y="290" width="210" height="40" as="geometry" />
