  <diagram id="page08" name="08 Context and Control Deep Dive">
    <mxGraphModel dx="2000" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p8n_title" value="CONTEXT, MEETING MODE, MEMORY, AND CONTROL CONTRACTS" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#1F2937;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1320" height="30" as="geometry" />
        </mxCell>
        <mxCell id="p8n_subtitle" value="No gaps page: this page is an implementation-level behavior map." style="text;html=1;fontSize=12;fillColor=none;strokeColor=none;fontColor=#374151;" vertex="1" parent="1">
          <mxGeometry x="40" y="52" width="900" height="24" as="geometry" />
        </mxCell>

        <mxCell id="p8n_bg_d" value="CASE D: Memory Update + Historical Query" style="rounded=1;fillColor=#E8EAF6;strokeColor=#3949AB;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#283593;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="1020" height="360" as="geometry" />
        </mxCell>
        <mxCell id="p8n_d1" value="User: &#39;My name is Alexei now.&#39;" style="rounded=1;fillColor=#C5CAE9;strokeColor=#3949AB;fontSize=11;fontColor=#1A237E;" vertex="1" parent="1">
          <mxGeometry x="70" y="150" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_d2" value="Main: memory update writes new active fact; old value becomes superseded" style="rounded=1;fillColor=#9FA8DA;strokeColor=#3949AB;fontSize=11;fontColor=#1A237E;" vertex="1" parent="1">
          <mxGeometry x="380" y="150" width="370" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_d3" value="Warm profile rebuild triggered" style="rounded=1;fillColor=#9FA8DA;strokeColor=#3949AB;fontSize=11;fontColor=#1A237E;" vertex="1" parent="1">
          <mxGeometry x="780" y="150" width="250" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_d4" value="User asks current + previous name" style="rounded=1;fillColor=#C5CAE9;strokeColor=#3949AB;fontSize=11;fontColor=#1A237E;" vertex="1" parent="1">
          <mxGeometry x="70" y="250" width="300" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_d5" value="Main to user: current active value + historical chain from versioned memory" style="rounded=1;fillColor=#80CBC4;strokeColor=#00695C;fontSize=11;fontColor=#004D40;" vertex="1" parent="1">
          <mxGeometry x="400" y="250" width="630" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_d6" value="Context rule: fetch only what is needed. No full history injected every turn." style="rounded=1;fillColor=#E8EAF6;strokeColor=#5C6BC0;fontSize=11;fontColor=#283593;" vertex="1" parent="1">
          <mxGeometry x="70" y="340" width="960" height="80" as="geometry" />
        </mxCell>

        <mxCell id="p8n_bg_e" value="CASE E: Meeting Mode (record-first workflow)" style="rounded=1;fillColor=#FFF3E0;strokeColor=#EF6C00;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1100" y="90" width="1060" height="360" as="geometry" />
        </mxCell>
        <mxCell id="p8n_e1" value="User: &#39;Start meeting mode.&#39;" style="rounded=1;fillColor=#FFE0B2;strokeColor=#FB8C00;fontSize=11;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="1130" y="150" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_e2" value="Main: &#39;Meeting mode is on. I will record and organize key points.&#39;" style="rounded=1;fillColor=#FFCC80;strokeColor=#EF6C00;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1400" y="150" width="420" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_e3" value="During meeting: diarization + transcript capture (minimal assistant chatter)" style="rounded=1;fillColor=#FFE0B2;strokeColor=#FB8C00;fontSize=11;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="1130" y="250" width="690" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_e4" value="User: &#39;End meeting mode.&#39;" style="rounded=1;fillColor=#FFE0B2;strokeColor=#FB8C00;fontSize=11;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="1850" y="150" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_e5" value="Post-meeting pipeline: summarize -> extract actions -> create reminders -> memory write" style="rounded=1;fillColor=#FFCC80;strokeColor=#EF6C00;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1850" y="250" width="280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p8n_e6" value="Later query: &#39;What did we decide last Tuesday?&#39;" style="rounded=1;fillColor=#FFE0B2;strokeColor=#FB8C00;fontSize=11;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="1130" y="340" width="360" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p8n_e7" value="Main recalls meeting summary + action decisions from memory" style="rounded=1;fillColor=#80CBC4;strokeColor=#00695C;fontSize=11;fontColor=#004D40;" vertex="1" parent="1">
          <mxGeometry x="1520" y="340" width="610" height="80" as="geometry" />
        </mxCell>

        <mxCell id="p8n_bg_f" value="CASE F: Multi-Tool Chain with Correct Ownership" style="rounded=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="40" y="480" width="2120" height="360" as="geometry" />
        </mxCell>
        <mxCell id="p8n_f1" value="User: &#39;Read latest client email, set reminder, and remember the final decision.&#39;" style="rounded=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="70" y="540" width="450" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_f2" value="Main to user: &#39;I will run this in three steps and report completion.&#39;" style="rounded=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="550" y="540" width="460" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_f3" value="Main delegates communication sub-agent for email/reminder actions" style="rounded=1;fillColor=#FFCCBC;strokeColor=#D84315;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1040" y="540" width="420" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_f4" value="Sub-agent STEP/DONE reports decision details back to Main" style="rounded=1;fillColor=#FFCCBC;strokeColor=#D84315;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1490" y="540" width="350" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_f5" value="Main direct memory_save for final decision" style="rounded=1;fillColor=#FFE082;strokeColor=#FF8F00;fontSize=11;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="1870" y="540" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_f6" value="Main to user: unified completion response + explicit fallback if one step failed" style="rounded=1;fillColor=#80CBC4;strokeColor=#00695C;fontSize=11;fontColor=#004D40;" vertex="1" parent="1">
          <mxGeometry x="70" y="640" width="2060" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_f7" value="Ownership contract: Main controls speaking and turn policy. Sub-agents can run broad tools but cannot control speaking/transport." style="rounded=1;fillColor=#F1F8E9;strokeColor=#689F38;fontSize=11;fontColor=#33691E;" vertex="1" parent="1">
          <mxGeometry x="70" y="730" width="2060" height="80" as="geometry" />
        </mxCell>

        <mxCell id="p8n_bg_c" value="CONTEXT PACK + COMPACTION TIMING" style="rounded=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="40" y="870" width="2120" height="300" as="geometry" />
        </mxCell>
        <mxCell id="p8n_c1" value="Turn context assembly: USER_PROFILE + ACTIVE_TASKS + TASK_SIGNALS + SESSION_CONTROL_STATE + RECENT_HISTORY (+ retrieval if needed)" style="rounded=1;fillColor=#D1C4E9;strokeColor=#7B1FA2;fontSize=11;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="70" y="930" width="2060" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_c2" value="Pre-response: fast token budget check only" style="rounded=1;fillColor=#FFF59D;strokeColor=#F9A825;fontSize=11;fontColor=#5D4037;" vertex="1" parent="1">
          <mxGeometry x="70" y="1020" width="480" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_c3" value="User-visible response path must stay fast" style="rounded=1;fillColor=#B2DFDB;strokeColor=#00796B;fontSize=11;fontColor=#004D40;" vertex="1" parent="1">
          <mxGeometry x="580" y="1020" width="480" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_c4" value="Post-response: enqueue compaction worker" style="rounded=1;fillColor=#CE93D8;strokeColor=#7B1FA2;fontSize=11;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="1090" y="1020" width="480" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_c5" value="Summarizer compresses old turns and keeps recent turns verbatim" style="rounded=1;fillColor=#CE93D8;strokeColor=#7B1FA2;fontSize=11;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="1600" y="1020" width="530" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_c6" value="Extracted stable facts are versioned in memory and become available for later retrieval" style="rounded=1;fillColor=#C5CAE9;strokeColor=#3949AB;fontSize=11;fontColor=#283593;" vertex="1" parent="1">
          <mxGeometry x="70" y="1110" width="2060" height="45" as="geometry" />
        </mxCell>

        <mxCell id="p8n_bg_ctrl" value="SHARED CONTROL CONTRACT" style="rounded=1;fillColor=#F5F5F5;strokeColor=#9E9E9E;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#424242;" vertex="1" parent="1">
          <mxGeometry x="40" y="1190" width="2120" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p8n_ctrl_main" value="Main Agent owns: user messaging, queue/replace policy, stop/resume speaking, task delegation, final answer synthesis." style="rounded=1;fillColor=#E0F2F1;strokeColor=#00796B;fontSize=11;fontColor=#004D40;" vertex="1" parent="1">
          <mxGeometry x="70" y="1245" width="1010" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8n_ctrl_sub" value="Sub-agents own: execution with broad non-speaking tools, structured reports (STEP/NEEDS_INFO/DONE/ERROR), and bounded retries." style="rounded=1;fillColor=#FBE9E7;strokeColor=#D84315;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1110" y="1245" width="1020" height="70" as="geometry" />
        </mxCell>

        <mxCell id="p8n_ed1" edge="1" parent="1" source="p8n_d1" target="p8n_d2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#3949AB;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p8n_ed2" edge="1" parent="1" source="p8n_d2" target="p8n_d3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#3949AB;">
          <mxGeometry relative="1" as="geometry" />
