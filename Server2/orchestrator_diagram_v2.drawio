  <diagram id="page09" name="09 Shared Engine Pool">
    <mxGraphModel dx="2000" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p9_title" value="SINGLE LITERT ENGINE POOL (STRUCTURAL VIEW)" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#1F2937;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="980" height="30" as="geometry" />
        </mxCell>
        <mxCell id="p9_bg_src" value="REQUEST SOURCES" style="rounded=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="620" height="1260" as="geometry" />
        </mxCell>
        <mxCell id="p9_bg_queue" value="PRIORITY QUEUE" style="rounded=1;fillColor=#FFF8E1;strokeColor=#F9A825;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#5D4037;" vertex="1" parent="1">
          <mxGeometry x="700" y="90" width="520" height="1260" as="geometry" />
        </mxCell>
        <mxCell id="p9_bg_engine" value="SHARED INFERENCE CORE" style="rounded=1;fillColor=#E3F2FD;strokeColor=#1E88E5;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#0D47A1;" vertex="1" parent="1">
          <mxGeometry x="1280" y="90" width="880" height="1260" as="geometry" />
        </mxCell>

        <mxCell id="p9_src_main" value="Main conversation turns&#xa;Permanent conversation slot owner&#xa;Enqueue priority: P0 (highest)" style="rounded=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="80" y="180" width="540" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p9_src_sub" value="Sub-agent task conversations&#xa;Ephemeral per task / per capability&#xa;Enqueue priority: P1 (normal)" style="rounded=1;fillColor=#FFCCBC;strokeColor=#D84315;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="80" y="370" width="540" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p9_src_sum" value="Summarizer conversations&#xa;Ephemeral compression/extraction calls&#xa;Enqueue priority: P2 (low, deferrable)" style="rounded=1;fillColor=#CE93D8;strokeColor=#7B1FA2;fontSize=11;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="80" y="560" width="540" height="140" as="geometry" />
        </mxCell>

        <mxCell id="p9_q_head" value="Priority dispatcher queue&#xa;All inference requests pass through this queue" style="rounded=1;fillColor=#FFF59D;strokeColor=#F9A825;fontStyle=1;fontSize=11;fontColor=#5D4037;" vertex="1" parent="1">
          <mxGeometry x="740" y="180" width="440" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p9_q_p0" value="P0 HIGH&#xa;Main user turns, interrupts, urgent control" style="rounded=1;fillColor=#FFE082;strokeColor=#FF8F00;fontSize=11;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="760" y="310" width="400" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p9_q_p1" value="P1 NORMAL&#xa;Sub-agent tool-step reasoning" style="rounded=1;fillColor=#FFE082;strokeColor=#FF8F00;fontSize=11;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="760" y="430" width="400" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p9_q_p2" value="P2 LOW&#xa;Summarizer and compaction jobs" style="rounded=1;fillColor=#FFE082;strokeColor=#FF8F00;fontSize=11;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="760" y="550" width="400" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p9_dispatch" value="Dispatcher pops highest available priority" style="rounded=1;fillColor=#FFF59D;strokeColor=#F9A825;fontSize=11;fontColor=#5D4037;" vertex="1" parent="1">
          <mxGeometry x="760" y="690" width="400" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p9_serial" value="Serialized access guarantee&#xa;exactly one active inference enters engine at a time" style="rounded=1;fillColor=#FFF59D;strokeColor=#F9A825;fontSize=11;fontColor=#5D4037;" vertex="1" parent="1">
          <mxGeometry x="760" y="820" width="400" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p9_busy_note" value="Busy-engine behavior (CPU LiteRT): no mid-step preemption.&#xa;If a higher-priority request arrives while a sub-agent step is running, that step completes, then dispatcher schedules the next highest-priority item." style="rounded=1;fillColor=#FFECB3;strokeColor=#F9A825;fontSize=11;fontColor=#5D4037;" vertex="1" parent="1">
          <mxGeometry x="760" y="940" width="400" height="120" as="geometry" />
        </mxCell>

        <mxCell id="p9_engine" value="LiteRT Engine (single shared instance)&#xa;One process-level runtime serving all lanes" style="rounded=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontStyle=1;fontSize=11;fontColor=#0D47A1;" vertex="1" parent="1">
          <mxGeometry x="1320" y="180" width="800" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p9_slot_main" value="Conversation slot A (permanent)&#xa;Main control-loop context" style="rounded=1;fillColor=#B2DFDB;strokeColor=#00796B;fontSize=11;fontColor=#004D40;" vertex="1" parent="1">
          <mxGeometry x="1360" y="390" width="720" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p9_slot_sub" value="Conversation slot B (ephemeral)&#xa;Sub-agent task context" style="rounded=1;fillColor=#FBE9E7;strokeColor=#D84315;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1360" y="550" width="720" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p9_slot_sum" value="Conversation slot C (ephemeral)&#xa;Summarizer context" style="rounded=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=11;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="1360" y="710" width="720" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p9_out" value="Responses route back to caller lane&#xa;Main/sub-agent/summarizer update their own state stores" style="rounded=1;fillColor=#E1F5FE;strokeColor=#0288D1;fontSize=11;fontColor=#01579B;" vertex="1" parent="1">
          <mxGeometry x="1360" y="890" width="720" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p9_note" value="Build rule: do not model separate always-on engines per role.&#xa;Main permanent conversation + sub-agent ephemeral conversations + summarizer ephemeral conversations all share one engine through the priority queue." style="rounded=1;fillColor=#F5F5F5;strokeColor=#9E9E9E;fontSize=11;fontColor=#424242;" vertex="1" parent="1">
          <mxGeometry x="80" y="1080" width="2040" height="120" as="geometry" />
        </mxCell>

        <mxCell id="p9_e1" value="enqueue P0" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#388E3C;" edge="1" parent="1" source="p9_src_main" target="p9_q_p0">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p9_e2" value="enqueue P1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#D84315;" edge="1" parent="1" source="p9_src_sub" target="p9_q_p1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p9_e3" value="enqueue P2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7B1FA2;" edge="1" parent="1" source="p9_src_sum" target="p9_q_p2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p9_e4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F9A825;" edge="1" parent="1" source="p9_q_p0" target="p9_dispatch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p9_e5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F9A825;" edge="1" parent="1" source="p9_q_p1" target="p9_dispatch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p9_e6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F9A825;" edge="1" parent="1" source="p9_q_p2" target="p9_dispatch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p9_e7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F9A825;" edge="1" parent="1" source="p9_dispatch" target="p9_serial">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p9_e7b" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F9A825;" edge="1" parent="1" source="p9_serial" target="p9_busy_note">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p9_e8" value="one inference at a time" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1565C0;" edge="1" parent="1" source="p9_serial" target="p9_engine">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p9_e9" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1565C0;" edge="1" parent="1" source="p9_engine" target="p9_slot_main">
