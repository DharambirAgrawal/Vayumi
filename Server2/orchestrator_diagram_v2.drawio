        </mxCell>
        <mxCell id="p3_case6" parent="1" style="rounded=1;fillColor=#FFF59D;strokeColor=#F9A825;fontSize=11;fontColor=#5D4037;" value="Case F: Human-in-the-loop&#xa;when NEEDS_INFO arrives, ask one targeted question and keep remaining workers active" vertex="1">
