        <mxCell id="p8n_ee1" edge="1" parent="1" source="p8n_e1" target="p8n_e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#EF6C00;">
          <mxGeometry relative="1" as="geometry" />
