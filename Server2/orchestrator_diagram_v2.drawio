  </diagram>
  <diagram id="page10" name="10 Proactive Notifier Flow">
    <mxGraphModel dx="2000" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p10_title" value="PROACTIVE NOTIFIER LOOP (DONE/NEEDS_INFO WITHOUT USER PROMPT)" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#1F2937;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1320" height="30" as="geometry" />
        </mxCell>
        <mxCell id="p10_lane1" value="LANE 1: BACKGROUND LOOP" style="rounded=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="650" height="1220" as="geometry" />
        </mxCell>
        <mxCell id="p10_lane2" value="LANE 2: GATES (SPEAKING + DEBOUNCE)" style="rounded=1;fillColor=#FFF8E1;strokeColor=#F9A825;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#5D4037;" vertex="1" parent="1">
          <mxGeometry x="730" y="120" width="650" height="1220" as="geometry" />
        </mxCell>
        <mxCell id="p10_lane3" value="LANE 3: MAIN SYNTHESIS + USER DELIVERY" style="rounded=1;fillColor=#E3F2FD;strokeColor=#1E88E5;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#0D47A1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="120" width="740" height="1220" as="geometry" />
        </mxCell>

        <mxCell id="p10_n1" value="Background tick / wakeup event&#xa;proactive notifier runs without waiting for user speech" style="rounded=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="90" y="200" width="540" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p10_n2" value="Peek signal bus&#xa;collect STEP / DONE / NEEDS_INFO / ERROR updates" style="rounded=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="90" y="340" width="540" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p10_n3" value="Select user-facing updates first&#xa;DONE + NEEDS_INFO (+ actionable ERROR)" style="rounded=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="90" y="480" width="540" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p10_n4" value="Batch by task and condense summaries&#xa;keep only relevant outcomes for context" style="rounded=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="90" y="620" width="540" height="90" as="geometry" />
        </mxCell>

        <mxCell id="p10_g1" value="Gate A: is_ai_speaking?" style="rhombus;fillColor=#FFF176;strokeColor=#F9A825;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="830" y="250" width="440" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p10_g1_wait" value="If YES: hold notification&#xa;wait for safe non-speaking window" style="rounded=1;fillColor=#FFECB3;strokeColor=#F9A825;fontSize=11;fontColor=#5D4037;" vertex="1" parent="1">
          <mxGeometry x="790" y="390" width="530" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p10_g2" value="Gate B: debounce/cooldown elapsed?" style="rhombus;fillColor=#FFF176;strokeColor=#F9A825;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="830" y="540" width="440" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p10_g2_wait" value="If NO: keep queued signal snapshot&#xa;retry on next notifier tick" style="rounded=1;fillColor=#FFECB3;strokeColor=#F9A825;fontSize=11;fontColor=#5D4037;" vertex="1" parent="1">
          <mxGeometry x="790" y="680" width="530" height="90" as="geometry" />
        </mxCell>

        <mxCell id="p10_m1" value="Build synthetic chat turn payload&#xa;task_id + concise DONE summary or NEEDS_INFO question" style="rounded=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;fontColor=#0D47A1;" vertex="1" parent="1">
          <mxGeometry x="1470" y="220" width="640" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p10_m2" value="Invoke Main turn handling&#xa;input_mode=chat, respond_via=chat_only, interrupt_policy=queue" style="rounded=1;fillColor=#B3E5FC;strokeColor=#0288D1;fontSize=11;fontColor=#01579B;" vertex="1" parent="1">
          <mxGeometry x="1470" y="370" width="640" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p10_m3" value="Main writes proactive user message&#xa;&#39;Task complete ...&#39; or &#39;Need one detail ...&#39;" style="rounded=1;fillColor=#B2DFDB;strokeColor=#00796B;fontSize=11;fontColor=#004D40;" vertex="1" parent="1">
          <mxGeometry x="1470" y="520" width="640" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p10_m4" value="Emit proactive UX events to client&#xa;task_complete / task_waiting + chatbot_response" style="rounded=1;fillColor=#90CAF9;strokeColor=#1E88E5;fontSize=11;fontColor=#0D47A1;" vertex="1" parent="1">
          <mxGeometry x="1470" y="670" width="640" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p10_m5" value="Update context state&#xa;pending_results + TASK_SIGNALS keep condensed relevant outcomes" style="rounded=1;fillColor=#CE93D8;strokeColor=#7B1FA2;fontSize=11;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="1470" y="820" width="640" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p10_m6" value="User receives completion/waiting update&#xa;without asking &#39;is it done yet?&#39;" style="rounded=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontStyle=1;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="1470" y="970" width="640" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p10_note" value="Contract: sub-agents never speak directly. They report statuses to signal bus; Main synthesizes user-facing proactive updates using chat-mode queue policy." style="rounded=1;fillColor=#F5F5F5;strokeColor=#9E9E9E;fontSize=11;fontColor=#424242;" vertex="1" parent="1">
          <mxGeometry x="90" y="1120" width="2020" height="100" as="geometry" />
        </mxCell>

        <mxCell id="p10_e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#388E3C;" edge="1" parent="1" source="p10_n1" target="p10_n2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p10_e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#388E3C;" edge="1" parent="1" source="p10_n2" target="p10_n3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p10_e3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#388E3C;" edge="1" parent="1" source="p10_n3" target="p10_n4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p10_e4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F9A825;" edge="1" parent="1" source="p10_n4" target="p10_g1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p10_e5" value="YES" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F9A825;" edge="1" parent="1" source="p10_g1" target="p10_g1_wait">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p10_e6" value="NO" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F9A825;" edge="1" parent="1" source="p10_g1" target="p10_g2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p10_e7" value="window opens" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F9A825;" edge="1" parent="1" source="p10_g1_wait" target="p10_g2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p10_e8" value="NO" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F9A825;" edge="1" parent="1" source="p10_g2" target="p10_g2_wait">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p10_e9" value="YES" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1565C0;" edge="1" parent="1" source="p10_g2" target="p10_m1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p10_e10" value="retry" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F9A825;" edge="1" parent="1" source="p10_g2_wait" target="p10_g2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p10_e11" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1E88E5;" edge="1" parent="1" source="p10_m1" target="p10_m2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p10_e12" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#00796B;" edge="1" parent="1" source="p10_m2" target="p10_m3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p10_e13" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1E88E5;" edge="1" parent="1" source="p10_m3" target="p10_m4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p10_e14" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7B1FA2;" edge="1" parent="1" source="p10_m4" target="p10_m5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p10_e15" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2E7D32;" edge="1" parent="1" source="p10_m5" target="p10_m6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
