  <diagram id="page02" name="02 Latency Critical Path">
    <mxGraphModel dx="2000" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p2_title" value="LATENCY-OPTIMIZED TURN PIPELINE" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#1F2937;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="680" height="30" as="geometry" />
        </mxCell>
        <mxCell id="p2_bg_fast" value="RESPONSE-CRITICAL PATH (must stay fast)" style="rounded=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="1120" height="560" as="geometry" />
        </mxCell>
        <mxCell id="p2_bg_async" value="POST-RESPONSE AND BACKGROUND WORK (non-blocking)" style="rounded=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="40" y="670" width="1120" height="430" as="geometry" />
        </mxCell>
        <mxCell id="p2_bg_guard" value="LONG-INPUT PROTECTION" style="rounded=1;fillColor=#FFF8E1;strokeColor=#F9A825;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#5D4037;" vertex="1" parent="1">
          <mxGeometry x="1190" y="80" width="920" height="1020" as="geometry" />
        </mxCell>
        <mxCell id="p2_start" value="User message arrives" style="ellipse;fillColor=#A5D6A7;strokeColor=#2E7D32;fontStyle=1;fontSize=12;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="90" y="140" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2_pre" value="Fast preflight&#xa;- estimate token load&#xa;- parse mode + task context" style="rounded=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="360" y="130" width="250" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p2_decision" value="Within context budget?" style="rhombus;fillColor=#FFF176;strokeColor=#F9A825;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="670" y="130" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p2_parallel" value="Concurrent I/O in parallel&#xa;- refresh session state&#xa;- collect pending task signals" style="rounded=1;fillColor=#B2DFDB;strokeColor=#00796B;fontSize=11;fontColor=#004D40;" vertex="1" parent="1">
          <mxGeometry x="920" y="130" width="210" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2_context" value="Build turn context&#xa;warm profile + active tasks + pending results" style="rounded=1;fillColor=#B2DFDB;strokeColor=#00796B;fontSize=11;fontColor=#004D40;" vertex="1" parent="1">
          <mxGeometry x="90" y="260" width="310" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p2_llm" value="Main reasoning starts&#xa;stream first text chunk quickly" style="rounded=1;fillColor=#80CBC4;strokeColor=#00695C;fontStyle=1;fontSize=11;fontColor=#004D40;" vertex="1" parent="1">
          <mxGeometry x="430" y="260" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p2_toolux" value="If tool needed: announce intent first&#xa;then run tool and stream progress" style="rounded=1;fillColor=#FFE082;strokeColor=#FF8F00;fontSize=11;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="720" y="260" width="320" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p2_tts" value="Voice rendering + playback starts" style="rounded=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontStyle=1;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="90" y="370" width="300" height="65" as="geometry" />
        </mxCell>
        <mxCell id="p2_done" value="User hears first response token" style="ellipse;fillColor=#66BB6A;strokeColor=#1B5E20;fontStyle=1;fontSize=12;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="430" y="378" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2_slo" value="Target: first useful response in about 1.0s (or better) on normal turns" style="rounded=1;fillColor=#E8F5E9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="720" y="370" width="370" height="65" as="geometry" />
        </mxCell>
        <mxCell id="p2_after" value="After response is sent" style="ellipse;fillColor=#CE93D8;strokeColor=#7B1FA2;fontStyle=1;fontSize=12;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="90" y="730" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2_check" value="Check history size and quality&#xa;If over soft threshold (e.g., &gt;20k), enqueue compression" style="rounded=1;fillColor=#D1C4E9;strokeColor=#7B1FA2;fontSize=11;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="360" y="720" width="350" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2_queue" value="Compression queue&#xa;idle windows + turn gaps" style="rounded=1;fillColor=#E1BEE7;strokeColor=#8E24AA;fontSize=11;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="750" y="720" width="190" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2_worker" value="Summarizer worker&#xa;compress oldest raw turns&#xa;keep recent turns verbatim" style="rounded=1;fillColor=#CE93D8;strokeColor=#7B1FA2;fontSize=11;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="970" y="720" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2_write" value="Write summary + update memory indexes" style="rounded=1;fillColor=#C5CAE9;strokeColor=#3949AB;fontSize=11;fontColor=#283593;" vertex="1" parent="1">
          <mxGeometry x="360" y="840" width="350" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p2_note" value="Compression is moved off the user-visible critical path.&#xa;It must not delay the first response." style="rounded=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontStyle=1;fontSize=11;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="750" y="840" width="390" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p2_long_start" value="If message is very long (chat paste / long dictation)" style="ellipse;fillColor=#FFE082;strokeColor=#F9A825;fontStyle=1;fontSize=11;fontColor=#5D4037;" vertex="1" parent="1">
          <mxGeometry x="1240" y="150" width="340" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2_ack" value="Immediate acknowledgement&#xa;&#39;I got it, processing this in chunks&#39;" style="rounded=1;fillColor=#FFECB3;strokeColor=#F9A825;fontStyle=1;fontSize=11;fontColor=#5D4037;" vertex="1" parent="1">
          <mxGeometry x="1240" y="230" width="340" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p2_chunk" value="Chunk + normalize input&#xa;dedupe, sectioning, citation extraction" style="rounded=1;fillColor=#FFF3E0;strokeColor=#FB8C00;fontSize=11;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="1610" y="230" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p2_async_agent" value="Async doc-analysis sub-agent&#xa;works on chunk set while user sees progress" style="rounded=1;fillColor=#FFCCBC;strokeColor=#D84315;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
