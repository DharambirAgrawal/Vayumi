  <diagram id="page05" name="05 Memory and Context Strategy">
    <mxGraphModel dx="2000" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p5_title" value="MEMORY AND CONTEXT STRATEGY (Latency-Aware)" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#1F2937;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="940" height="30" as="geometry" />
        </mxCell>
        <mxCell id="p5_bg_layers" value="THREE-LAYER MEMORY MODEL" style="rounded=1;fillColor=#E8EAF6;strokeColor=#3949AB;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#283593;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="980" height="940" as="geometry" />
        </mxCell>
        <mxCell id="p5_bg_turn" value="PER-TURN CONTEXT PACK" style="rounded=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="1060" y="80" width="500" height="940" as="geometry" />
        </mxCell>
        <mxCell id="p5_bg_write" value="WRITE PATHS + VERSIONING" style="rounded=1;fillColor=#FFF3E0;strokeColor=#EF6C00;strokeWidth=2;verticalAlign=top;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1600" y="80" width="560" height="940" as="geometry" />
        </mxCell>
        <mxCell id="p5_l1" value="Layer 1: Warm Profile (always in context)&#xa;- identity and preferences&#xa;- communication style&#xa;- rebuilt only when warm_profile_dirty is set" style="rounded=1;fillColor=#9FA8DA;strokeColor=#3949AB;fontStyle=1;fontSize=11;fontColor=#1A237E;" vertex="1" parent="1">
          <mxGeometry x="80" y="140" width="880" height="95" as="geometry" />
        </mxCell>
        <mxCell id="p5_l2" value="Layer 2: On-demand retrieval&#xa;- used only for specific historical lookups&#xa;- not fetched on every turn" style="rounded=1;fillColor=#C5CAE9;strokeColor=#3949AB;fontSize=11;fontColor=#1A237E;" vertex="1" parent="1">
          <mxGeometry x="80" y="270" width="880" height="85" as="geometry" />
        </mxCell>
        <mxCell id="p5_l3" value="Layer 3: Versioned fact store&#xa;- active facts for current behavior&#xa;- superseded chain for historical questions" style="rounded=1;fillColor=#C5CAE9;strokeColor=#3949AB;fontSize=11;fontColor=#1A237E;" vertex="1" parent="1">
          <mxGeometry x="80" y="390" width="880" height="85" as="geometry" />
        </mxCell>
        <mxCell id="p5_chain" value="Example version chain&#xa;name: Alex (inactive) -&gt; Alexei (active)&#xa;history remains queryable" style="rounded=1;fillColor=#E8EAF6;strokeColor=#5C6BC0;fontSize=11;fontColor=#283593;" vertex="1" parent="1">
          <mxGeometry x="80" y="510" width="880" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p5_comp" value="Compression policy&#xa;- soft threshold at history &gt; 20k tokens&#xa;- enqueue after assistant response&#xa;- run in idle windows" style="rounded=1;fillColor=#D1C4E9;strokeColor=#7B1FA2;fontStyle=1;fontSize=11;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="80" y="620" width="880" height="95" as="geometry" />
        </mxCell>
        <mxCell id="p5_long" value="Long message guard&#xa;- preflight token estimate before inference&#xa;- chunk + summarize if needed&#xa;- continue with bounded context" style="rounded=1;fillColor=#FFE082;strokeColor=#F9A825;fontSize=11;fontColor=#5D4037;" vertex="1" parent="1">
          <mxGeometry x="80" y="750" width="880" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p5_budget" value="Context budget guidance (example for 32k window)&#xa;developer prompt + turn context + history + user input + output headroom" style="rounded=1;fillColor=#F5F5F5;strokeColor=#9E9E9E;fontSize=11;fontColor=#424242;" vertex="1" parent="1">
          <mxGeometry x="80" y="880" width="880" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p5_turn1" value="Turn Context Block" style="rounded=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontStyle=1;fontSize=12;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="1090" y="140" width="440" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p5_turn2" value="1) Warm profile" style="rounded=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="1110" y="220" width="400" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p5_turn3" value="2) Active tasks and latest status" style="rounded=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="1110" y="295" width="400" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p5_turn4" value="3) Pending task results" style="rounded=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="1110" y="370" width="400" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p5_turn5" value="4) Session state" style="rounded=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="1110" y="445" width="400" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p5_turn6" value="5) Retrieval results (only if requested)" style="rounded=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="1110" y="520" width="400" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p5_turn7" value="No heavy compression on this path" style="rounded=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;fontColor=#B71C1C;" vertex="1" parent="1">
          <mxGeometry x="1110" y="610" width="400" height="65" as="geometry" />
        </mxCell>
        <mxCell id="p5_turn8" value="Compression + extraction run asynchronously after response" style="rounded=1;fillColor=#CE93D8;strokeColor=#7B1FA2;fontSize=11;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="1110" y="695" width="400" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p5_w1" value="Write source A&#xa;Main memory_save for profile-affecting facts" style="rounded=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1630" y="150" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p5_w2" value="Write source B&#xa;Summarizer after task completion" style="rounded=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1890" y="150" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p5_w3" value="Write source C&#xa;Compression fact extraction" style="rounded=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1630" y="250" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p5_w4" value="Write source D&#xa;Explicit user &#39;remember this&#39; intent" style="rounded=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1890" y="250" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p5_store" value="Versioned memory store&#xa;active flag + superseded links + timestamps" style="rounded=1;fillColor=#FFCC80;strokeColor=#EF6C00;fontStyle=1;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1630" y="380" width="500" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p5_rebuild" value="Set warm_profile_dirty=true&#xa;when active profile facts are updated" style="rounded=1;fillColor=#C5CAE9;strokeColor=#3949AB;fontSize=11;fontColor=#283593;" vertex="1" parent="1">
          <mxGeometry x="1630" y="500" width="500" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p5_rebuild_next" value="Next turn start (including synthetic proactive turns): if warm_profile_dirty&#xa;run warm_block.rebuild() once, then clear dirty flag" style="rounded=1;fillColor=#E8EAF6;strokeColor=#3949AB;fontSize=11;fontColor=#283593;" vertex="1" parent="1">
          <mxGeometry x="1630" y="600" width="500" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p5_history_query" value="Historical query path (on-demand only)&#xa;&#39;what was true before?&#39; uses superseded chain lookup" style="rounded=1;fillColor=#E8EAF6;strokeColor=#5C6BC0;fontSize=11;fontColor=#283593;" vertex="1" parent="1">
          <mxGeometry x="1630" y="690" width="500" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p5_guardrail" value="Guardrails&#xa;- no silent overwrite of prior facts&#xa;- preserve provenance for trust and debugging&#xa;- bounded token footprint per turn" style="rounded=1;fillColor=#F5F5F5;strokeColor=#9E9E9E;fontSize=11;fontColor=#424242;" vertex="1" parent="1">
          <mxGeometry x="1630" y="790" width="500" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p5_e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#3949AB;" edge="1" parent="1" source="p5_l1" target="p5_turn1">
