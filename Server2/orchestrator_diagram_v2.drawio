        <mxCell id="p3_case8" parent="1" style="rounded=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;fontColor=#B71C1C;" value="Guardrails&#xa;- capability-scoped tools per agent&#xa;- bounded retries and step limits&#xa;- explicit handoff contracts" vertex="1">
