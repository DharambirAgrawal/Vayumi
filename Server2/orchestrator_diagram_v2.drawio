        </mxCell>
        <mxCell id="p3_case5" parent="1" style="rounded=1;fillColor=#FFE0B2;strokeColor=#FB8C00;fontSize=11;fontColor=#E65100;" value="Case E: Long document intake&#xa;ack now, chunk asynchronously, keep user informed, synthesize once complete" vertex="1">
