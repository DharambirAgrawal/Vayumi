        </mxCell>
        <mxCell id="p3_case7" parent="1" style="rounded=1;fillColor=#B2DFDB;strokeColor=#00796B;fontStyle=1;fontSize=12;fontColor=#004D40;" value="Design outcome&#xa;Feels like one assistant, powered by many coordinated specialist loops" vertex="1">
