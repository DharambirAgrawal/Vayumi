        </mxCell>
        <mxCell id="p4_c2_t1" value="Turn 1 user&#xa;Describes issue + identity info" style="rounded=1;fillColor=#BBDEFB;strokeColor=#1E88E5;fontSize=11;fontColor=#0D47A1;" vertex="1" parent="1">
          <mxGeometry x="790" y="140" width="190" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p4_c2_t2" value="Turn 1 assistant&#xa;Empathy + verification steps" style="rounded=1;fillColor=#B2DFDB;strokeColor=#00796B;fontSize=11;fontColor=#004D40;" vertex="1" parent="1">
          <mxGeometry x="1000" y="140" width="190" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p4_c2_t3" value="Turn 2 assistant&#xa;Queries policy + account tools" style="rounded=1;fillColor=#FFE082;strokeColor=#FF8F00;fontSize=11;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="1210" y="140" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p4_c2_t4" value="Turn 3 assistant&#xa;Resolution + next actions" style="rounded=1;fillColor=#B2DFDB;strokeColor=#00796B;fontSize=11;fontColor=#004D40;" vertex="1" parent="1">
          <mxGeometry x="1000" y="250" width="410" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p4_c3_t1" value="Turn 1 user&#xa;Urgent technical scenario" style="rounded=1;fillColor=#FFE0B2;strokeColor=#FB8C00;fontSize=11;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="1510" y="140" width="190" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p4_c3_t2" value="Turn 1 assistant&#xa;Calm framing + immediate triage" style="rounded=1;fillColor=#FFCCBC;strokeColor=#D84315;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1720" y="140" width="190" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p4_c3_t3" value="Turn 2 assistant&#xa;Parallel checks + risk ranking" style="rounded=1;fillColor=#FFCCBC;strokeColor=#D84315;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1930" y="140" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p4_c3_t4" value="Turn 3 user interrupt" style="rounded=1;fillColor=#FFF59D;strokeColor=#F9A825;fontSize=11;fontColor=#5D4037;" vertex="1" parent="1">
          <mxGeometry x="1510" y="250" width="190" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p4_c3_t5" value="Turn 3 assistant&#xa;adapts instantly, keeps background tasks running" style="rounded=1;fillColor=#FFCCBC;strokeColor=#D84315;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1720" y="250" width="410" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p4_c4_flow1" value="Turn 1 user sends very long message" style="rounded=1;fillColor=#D1C4E9;strokeColor=#673AB7;fontSize=11;fontColor=#311B92;" vertex="1" parent="1">
          <mxGeometry x="80" y="770" width="250" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p4_c4_flow2" value="Assistant replies quickly&#xa;&#39;Received, processing this in chunks&#39;" style="rounded=1;fillColor=#CE93D8;strokeColor=#7B1FA2;fontSize=11;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="360" y="770" width="280" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p4_c4_flow3" value="Main LLM chunk planner&#xa;(budget + pass order)" style="rounded=1;fillColor=#FFCCBC;strokeColor=#D84315;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="680" y="770" width="220" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p4_c4_flow4" value="Delegated sub-agent pass&#xa;for tool-heavy chunks" style="rounded=1;fillColor=#FFCCBC;strokeColor=#D84315;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="930" y="770" width="220" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p4_c4_flow5" value="STEP/DONE back to Main&#xa;Main condenses relevant findings" style="rounded=1;fillColor=#FFCCBC;strokeColor=#D84315;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="1180" y="770" width="240" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p4_c4_flow6" value="Main (same control loop) merges outputs&#xa;and starts streamed final answer&#xa;(no separate coordinator node)" style="rounded=1;fillColor=#80CBC4;strokeColor=#00695C;fontStyle=1;fontSize=11;fontColor=#004D40;" vertex="1" parent="1">
          <mxGeometry x="1450" y="770" width="320" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p4_c4_flow7" value="After answer: background compression if needed" style="rounded=1;fillColor=#C5CAE9;strokeColor=#3949AB;fontSize=11;fontColor=#283593;" vertex="1" parent="1">
          <mxGeometry x="1800" y="770" width="330" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p4_c4_rules" value="Behavior rules across all cases&#xa;1) Fast acknowledgement before heavy work&#xa;2) Tool intent preview before execution&#xa;3) Compression and summarization happen after response&#xa;4) Interruptions stop speech, not background task graph&#xa;5) Multi-task completions are condensed to relevant context before next turn" style="rounded=1;fillColor=#F5F5F5;strokeColor=#9E9E9E;fontSize=11;fontColor=#424242;" vertex="1" parent="1">
          <mxGeometry x="80" y="890" width="2050" height="90" as="geometry" />
        </mxCell>
