        <mxCell id="p7n_a_final" parent="1" style="rounded=1;fillColor=#80CBC4;strokeColor=#00695C;fontSize=11;fontColor=#004D40;" value="Main to user: &#39;I found BTC around $X from recent sources. Want 24h high/low too?&#39;" vertex="1">
