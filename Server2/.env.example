# ── App ──────────────────────────────────────────────────
APP_ENV=dev                         # dev | prod
PORT=8080
LOG_LEVEL=info

# ── Server 1 handshake (optional in dev) ────────────────
# JWT_PUBLIC_KEY=                   # RS256 PEM — same as Server 1's public key
# SERVER1_REDIS_URL=                # blocklist lookups (jti); often same URL as REDIS_URL when shared

# ── Database (often same cloud Postgres as Server 1) ─────
# Server 2 only creates its own tables — never writes Server 1 user/session tables.
DATABASE_URL=postgresql://user:pass@host:5432/postgres
LANCEDB_DIR=./data/lancedb

# ── Redis (often same cloud Redis as Server 1) ───────────
REDIS_URL=redis://default:password@host:port/0

# Optional local dev instead of cloud (requires Docker):
# DATABASE_URL=postgresql://vayumi:vayumi@localhost:5432/vayumi
# REDIS_URL=redis://localhost:6379/0
# Run: docker compose -f docker-compose.dev.yml up -d

# ── Engine overrides (optional; defaults live in server/config.py) ─────
# Set these only when your local paths or port differ from the defaults.
# LLAMA_SERVER_BIN=./bin/llama-server
# LLAMA_MODEL_PATH=./models/gemma-3n-E2B-it-Q4_K_M.gguf
# LLAMA_PORT=8081
# LLAMA_PARALLEL_SLOTS=4
# LLAMA_CTX_PER_SLOT=8192

# ── Voice (optional overrides; defaults in server/config.py) ───────────
# STT_BACKEND=groq
GROQ_API_KEY=
# KOKORO_MODEL_DIR=./models/kokoro
# KOKORO_VOICE=af_heart
