# ── App ──────────────────────────────────────────────────
APP_ENV=dev                         # dev | prod
PORT=8080
LOG_LEVEL=info

# ── Server 1 handshake (optional in dev) ────────────────
# JWT_PUBLIC_KEY=                   # RS256 PEM — same as Server 1's public key
# SERVER1_REDIS_URL=                # blocklist lookups (jti); often same URL as REDIS_URL when shared

# ── Database (often same cloud Postgres as Server 1) ─────
# Server 2 only creates its own tables — never writes Server 1 user/session tables.
DATABASE_URL=postgresql://user:pass@host:5432/postgres
LANCEDB_DIR=./data/lancedb

# ── Redis (often same cloud Redis as Server 1) ───────────
REDIS_URL=redis://default:password@host:port/0

# Typical dev (no Docker): use your cloud Postgres + Redis URLs here.
# DATABASE_URL=postgresql://user:pass@your-supabase-host:5432/postgres
# REDIS_URL=redis://default:password@your-redis-host:port/0

# Optional local only (requires: docker compose -f docker-compose.dev.yml up -d):
# DATABASE_URL=postgresql://vayumi:vayumi@localhost:5432/vayumi
# REDIS_URL=redis://localhost:6379/0

# ── Database pool (optional overrides) ─────────────────
# DB_POOL_MIN_SIZE=2
# DB_POOL_MAX_SIZE=10

# ── Engine overrides (optional; defaults live in server/config.py) ─────
# Set these only when your local paths or port differ from the defaults.
# LLAMA_SERVER_BIN=./bin/llama-server
# LLAMA_MODEL_PATH=./models/gemma-3n-E2B-it-Q4_K_M.gguf
# LLAMA_PORT=8081
# LLAMA_PARALLEL_SLOTS=4
# LLAMA_CTX_PER_SLOT=8192

# ── Embeddings (optional; encoder loads BAAI/bge-small-en-v1.5 via sentence-transformers) ──
# BGE_MODEL_PATH=./models/bge-small-en-v1.5.onnx

# ── Voice (optional overrides; defaults in server/config.py) ───────────
# STT_BACKEND=groq
GROQ_API_KEY=
# KOKORO_MODEL_DIR=./models/tts
# KOKORO_VOICE=af_heart
# SELF_ECHO_SUPPRESSION_DELAY_MS=1200
# AEC_CLIENT_SUPPRESSION_DELAY_MS=300
# SESSION_SINGLETON_CLOSE_CODE=4001

# ── Session summarizer (optional overrides; background P2) ─
# SUMMARIZER_TOKEN_THRESHOLD=20000
# SUMMARIZER_RECENT_TURN_KEEP=8
# SUMMARIZER_MAX_RETRIES=2
# SUMMARIZER_MIN_FACT_CONFIDENCE=0.75

# ── Proactive notifier (optional overrides) ──────────────
# NOTIFIER_TICK_SECONDS=3.0
# NOTIFIER_MIN_INTERVAL_SECONDS=45.0
# NOTIFIER_IMPORTANCE_THRESHOLD=0.5

# ── Tools (optional) ─────────────────────────────────────
# TAVILY_API_KEY=                   # web_search + deep_search; DDG fallback if unset
