          <mxGeometry x="1860" y="440" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s8m2" value="session_history.recent(N=8)&#10;raw turns + last summary" style="rounded=1;fillColor=#A5B4FC;strokeColor=#4338CA;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1860" y="510" width="500" height="60" as="geometry" />
        </mxCell>
