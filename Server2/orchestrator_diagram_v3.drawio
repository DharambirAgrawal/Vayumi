        <mxCell id="mem3" parent="1" style="rounded=1;fillColor=#A5B4FC;strokeColor=#4338CA;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" value="memory.facts.set(email.work, …)&#10;TX:&#10;1) old row id=f_77 -&gt; active=false, superseded_by=f_91&#10;2) insert new row f_91 active=true&#10;3) re-embed -&gt; LanceDB facts_index upsert&#10;4) warm.dirty=True&#10;commit" vertex="1">
