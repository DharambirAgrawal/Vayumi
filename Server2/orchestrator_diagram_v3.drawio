          <mxGeometry x="1840" y="100" width="540" height="1300" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="user finishes wake&#10;starts speaking&#10;t=0" style="ellipse;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=11;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="80" y="160" width="320" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="client local VAD detects speech&#10;send audio_start, then PCM chunks (every 20ms)" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
