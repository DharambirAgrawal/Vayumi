          <mxGeometry x="40" y="120" width="450" height="80" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="WS sends chat { text, attachments? }" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="450" height="60" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="Transport routes JSON&#10;Supervisor.handle_turn({kind:'chat', text, attachments})" style="rounded=1;fillColor=#DDD6FE;strokeColor=#6D28D9;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="540" y="220" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="att" value="Attachment policy (Phase 2)&#10;• image -&gt; OCR + caption tool (sub-agent)&#10;• audio -&gt; STT tool (re-uses Whisper)&#10;• video -&gt; frame sampler + caption tool&#10;• link -&gt; trafilatura -&gt; doc_chunks in LanceDB&#10;Output of attachment processing becomes a virtual user message&#10;injected before the real text turn." style="rounded=1;fillColor=#FFF7ED;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="540" y="320" width="500" height="200" as="geometry" />
        </mxCell>
        <mxCell id="ck" value="CONTEXT pack (same as voice turn)&#10;warm + task_board + history + chat_text" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1080" y="220" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ce" value="engine.pool.submit(P0, slot 0)&#10;Main streams text" style="rounded=1;fillColor=#FDBA74;strokeColor=#9A3412;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1080" y="320" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cd" value="directives parser&#10;[DELEGATE], [REMEMBER], [RECALL]" style="rounded=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1080" y="400" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="resp_policy" value="RESPONSE POLICY (per turn)&#10;respond_via = inferred from input.kind:&#10;• voice -&gt; voice + caption&#10;• chat  -&gt; chat only (no TTS)&#10;• proactive (notifier) -&gt; chat only&#10;User can override with `mode` message" style="rounded=1;fillColor=#DCFCE7;strokeColor=#388E3C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1080" y="480" width="500" height="160" as="geometry" />
        </mxCell>
        <mxCell id="cout" value="ws sends caption frames as the model streams&#10;type='caption', partial=true … then partial=false" style="rounded=1;fillColor=#DDD6FE;strokeColor=#6D28D9;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="540" y="660" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cdone" value="user sees streaming text in chat&#10;same UX as ChatGPT-style streaming" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="660" width="450" height="80" as="geometry" />
        </mxCell>
        <mxCell id="bg" value="Same post-turn pipeline as voice (page 4):&#10;append history -&gt; (maybe) summarize -&gt; (maybe) update facts -&gt; warm.dirty" style="rounded=1;fillColor=#E9D5FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="760" width="1540" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rule" value="DESIGN RULE&#10;Voice and chat go through the SAME Supervisor.handle_turn function.&#10;input.kind is metadata; the Main Agent is unaware which transport delivered the text.&#10;This guarantees feature parity between modes." style="rounded=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="870" width="1540" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ec1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2563EB;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="c1" target="c2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6D28D9;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="c2" target="c3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C2410C;dashed=1;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="c3" target="att">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#EA580C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="c3" target="ck">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#EA580C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="ck" target="ce">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9A3412;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="ce" target="cd">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#388E3C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="cd" target="resp_policy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec8" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6D28D9;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="resp_policy" target="cout">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec9" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2563EB;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="cout" target="cdone">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p06" name="06 Engine Pool">
    <mxGraphModel dx="2200" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" value="ENGINE POOL — one llama-server, 4 parallel slots, priority queue" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="Why this works: llama.cpp's -np N gives true parallel decode; each slot has its own KV cache. Our queue picks WHICH request goes next; the engine handles the parallelism." style="text;html=1;fontSize=12;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="56" width="2100" height="22" as="geometry" />
        </mxCell>
        <mxCell id="src" value="REQUEST SOURCES" style="rounded=1;fillColor=#E8F5E9;strokeColor=#16A34A;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="600" height="1240" as="geometry" />
        </mxCell>
        <mxCell id="src_main" value="Supervisor.run_main_turn (P0)&#10;sticky slot 0 — Main Agent context&#10;preempts everything below" style="rounded=1;fillColor=#99F6E4;strokeColor=#0F766E;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="560" height="100" as="geometry" />
        </mxCell>
        <mxCell id="src_sub" value="Sub-Agent.tick (P1)&#10;ephemeral; gets any free slot among {1,2,3}&#10;own conversation context per task" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="290" width="560" height="100" as="geometry" />
        </mxCell>
        <mxCell id="src_sum" value="Summarizer.compress (P2)&#10;runs in idle gaps&#10;deferrable; cancellable mid-prompt" style="rounded=1;fillColor=#E9D5FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="420" width="560" height="100" as="geometry" />
        </mxCell>
        <mxCell id="src_proac" value="Proactive notifier (P0)&#10;synthetic chat-turn invocation when DONE/NEEDS_INFO arrives and user is silent" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="550" width="560" height="100" as="geometry" />
        </mxCell>
        <mxCell id="qbox" value="PRIORITY QUEUE (engine/pool.py)" style="rounded=1;fillColor=#FEF3C7;strokeColor=#CA8A04;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="680" y="100" width="600" height="1240" as="geometry" />
        </mxCell>
        <mxCell id="q_p0" value="P0 lane (asyncio.PriorityQueue)&#10;Main turns + interrupts + proactive synth turns&#10;target wait: ~0ms (engine usually free)" style="rounded=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="700" y="160" width="560" height="100" as="geometry" />
        </mxCell>
        <mxCell id="q_p1" value="P1 lane&#10;Sub-agent steps&#10;target wait: &lt; 200ms when not preempted" style="rounded=1;fillColor=#FFD180;strokeColor=#D97706;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="700" y="290" width="560" height="100" as="geometry" />
        </mxCell>
        <mxCell id="q_p2" value="P2 lane&#10;Summarizer/extractor jobs&#10;cancelled if a P0 wakes up" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="700" y="420" width="560" height="100" as="geometry" />
        </mxCell>
        <mxCell id="dispatcher" value="dispatcher loop (single asyncio task)&#10;while True:&#10;  pop highest-priority READY job&#10;  pick free slot (or block until one frees)&#10;  POST to llama-server /completion?slot_id=K  with stream=true&#10;  fan-out tokens to caller's queue" style="rounded=1;fillColor=#FEF08A;strokeColor=#CA8A04;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="700" y="560" width="560" height="160" as="geometry" />
        </mxCell>
        <mxCell id="preempt" value="PREEMPTION RULE (CPU LiteRT-style)&#10;llama.cpp does not preempt mid-step.&#10;If a P0 arrives while a P1/P2 step is running on its slot:&#10;  • current step finishes (≤ N tokens)&#10;  • next dispatcher pick will be the P0&#10;  • Main is sticky on slot 0 -&gt; never blocked&#10;  • Summarizer is also cooperatively cancellable between sentences" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="700" y="740" width="560" height="180" as="geometry" />
        </mxCell>
        <mxCell id="eng" value="llama-server (subprocess)" style="rounded=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1320" y="100" width="800" height="1240" as="geometry" />
        </mxCell>
        <mxCell id="eng_proc" value="single process, model loaded once&#10;-np 4  --ctx-size 32768  --slot-prompt-similarity 0.5&#10;HTTP at 127.0.0.1:8081" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1340" y="160" width="760" height="80" as="geometry" />
        </mxCell>
        <mxCell id="slot0" value="slot 0 (sticky) — MAIN AGENT&#10;~8k ctx&#10;system prompt cached&#10;KV reused across turns" style="rounded=1;fillColor=#99F6E4;strokeColor=#0F766E;fontStyle=1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1340" y="270" width="760" height="120" as="geometry" />
        </mxCell>
        <mxCell id="slot1" value="slot 1 (ephemeral) — SUB-AGENT A&#10;research capability prompt + tools&#10;separate KV; vanishes when task DONE" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1340" y="410" width="760" height="120" as="geometry" />
        </mxCell>
        <mxCell id="slot2" value="slot 2 (ephemeral) — SUB-AGENT B&#10;productivity / comms / data" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1340" y="550" width="760" height="100" as="geometry" />
        </mxCell>
        <mxCell id="slot3" value="slot 3 (ephemeral) — SUMMARIZER&#10;short prompts; fact extraction schema" style="rounded=1;fillColor=#E9D5FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1340" y="670" width="760" height="100" as="geometry" />
        </mxCell>
        <mxCell id="kv_note" value="KV cache strategy&#10;• system prompt fingerprint per slot -&gt; reuse across calls&#10;• Main slot keeps growing KV until forced compaction&#10;• Sub-agent slot is wiped at task end (free KV instantly)&#10;• --slot-prompt-similarity 0.5 lets engine pick the slot whose KV best matches the new prompt -&gt; faster prefill" style="rounded=1;fillColor=#E0F2FE;strokeColor=#0369A1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1340" y="800" width="760" height="160" as="geometry" />
        </mxCell>
        <mxCell id="health" value="HEALTH CHECKS&#10;• /health every 5s; if 3 fail -&gt; restart subprocess (graceful)&#10;• /slots every 30s -&gt; structured log of KV usage per slot&#10;• if slot KV &gt; 90% -&gt; trigger an immediate summarizer compaction for that conversation" style="rounded=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1340" y="980" width="760" height="160" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="P0" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0F766E;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="src_main" target="q_p0">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="P0" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#16A34A;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="src_proac" target="q_p0">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="P1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C2410C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="src_sub" target="q_p1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="P2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7C3AED;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="src_sum" target="q_p2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CA8A04;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="q_p0" target="dispatcher">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CA8A04;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="q_p1" target="dispatcher">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CA8A04;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="q_p2" target="dispatcher">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" value="HTTP /completion?slot_id=0" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2563EB;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="dispatcher" target="slot0">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" value="slot 1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2563EB;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="dispatcher" target="slot1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" value="slot 2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2563EB;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="dispatcher" target="slot2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" value="slot 3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2563EB;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="dispatcher" target="slot3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p07" name="07 Sub-agent Lifecycle">
    <mxGraphModel dx="2400" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" value="SUB-AGENT LIFECYCLE — spawn, work, report, finish" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="m1" value="Main Agent token stream contains:&#10;[DELEGATE capability=research goal=&quot;summarize URL X in 5 bullets&quot; payload={url:…}]" style="rounded=1;fillColor=#99F6E4;strokeColor=#0F766E;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="640" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m2" value="directives.parser validates capability + payload schema&#10;rejects unknown capability with parse error -&gt; Main retries silently" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="180" width="640" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m3" value="Supervisor.spawn_subagent(capability, goal, payload)&#10;creates Task(task_id=t1, capability=research)&#10;writes row to PG: tasks(status=running)&#10;adds to task_board" style="rounded=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="640" height="120" as="geometry" />
        </mxCell>
        <mxCell id="m4" value="emit event{kind:'tool_started', task_id, summary}&#10;-&gt; client UX shows activity feed entry" style="rounded=1;fillColor=#FEF08A;strokeColor=#CA8A04;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="640" height="80" as="geometry" />
        </mxCell>
        <mxCell id="sa" value="SubAgentWorker(task_id, capability)" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontStyle=1;fontSize=12;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="720" y="80" width="600" height="60" as="geometry" />
        </mxCell>
        <mxCell id="sa1" value="1) load capability bundle&#10;• prompt: prompts/sub/research.txt&#10;• tool_subset: web_search, summarize_url, fetch_html, memory_recall&#10;• acceptable report kinds: STEP, NEEDS_INFO, DONE, ERROR" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="720" y="160" width="600" height="120" as="geometry" />
        </mxCell>
        <mxCell id="sa2" value="2) build prompt = system + capability_prompt + tool_schemas + goal + payload&#10;allocate llama slot {1|2|3}&#10;submit P1" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="720" y="300" width="600" height="100" as="geometry" />
        </mxCell>
        <mxCell id="sa3" value="3) sub-agent thinks; writes&#10;[CALL fetch_html url=…]&#10;orchestrator runs the tool, injects result&#10;sub-agent continues until it can write report(DONE,…)" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="720" y="420" width="600" height="120" as="geometry" />
        </mxCell>
        <mxCell id="sa4" value="4) report() schema (Pydantic-validated)&#10;{task_id, kind: 'STEP'|'NEEDS_INFO'|'DONE'|'ERROR',&#10; summary: str (≤ 80 tok),&#10; payload: dict (capability-specific),&#10; ts: iso8601}" style="rounded=1;fillColor=#FFD3C2;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="720" y="560" width="600" height="140" as="geometry" />
        </mxCell>
        <mxCell id="sa5" value="5) bounded retry policy&#10;• step time-budget: 90s&#10;• max consecutive errors: 2&#10;• max steps: 8 (configurable per capability)&#10;exceed -&gt; report(ERROR, reason)" style="rounded=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="720" y="720" width="600" height="120" as="geometry" />
        </mxCell>
        <mxCell id="bus" value="SIGNAL BUS (asyncio queue + Redis pub/sub)" style="rounded=1;fillColor=#E0F2FE;strokeColor=#0369A1;fontStyle=1;fontSize=12;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1360" y="80" width="640" height="60" as="geometry" />
        </mxCell>
        <mxCell id="b1" value="every report() goes here first&#10;persisted to PG signals table for audit" style="rounded=1;fillColor=#B3E5FC;strokeColor=#0369A1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1360" y="160" width="640" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b2" value="Supervisor.signal_drainer (always running)&#10;consumes signals; updates task_board" style="rounded=1;fillColor=#B3E5FC;strokeColor=#0369A1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1360" y="260" width="640" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b3" value="Routing rule&#10;• STEP   -&gt; update task_board.latest_progress only (no LLM call)&#10;• DONE   -&gt; if user idle: notifier picks it up; else feed to next Main turn&#10;• NEEDS_INFO -&gt; notifier always picks it up (user blocking)&#10;• ERROR  -&gt; same as NEEDS_INFO (user-actionable) or auto-retry once" style="rounded=1;fillColor=#B3E5FC;strokeColor=#0369A1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1360" y="360" width="640" height="180" as="geometry" />
        </mxCell>
        <mxCell id="b4" value="DONE handling&#10;• summarize sub-agent result via summarizer (P2)&#10;• extract any new facts -&gt; memory.facts.set (versioned)&#10;• free llama slot&#10;• PG: tasks(status=done, result_summary)&#10;• emit event{kind:'task_done'}" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1360" y="560" width="640" height="160" as="geometry" />
        </mxCell>
        <mxCell id="rules" value="HARD RULES&#10;• Sub-agents NEVER write to client transport directly.&#10;• Sub-agents see ONLY their capability's tool schemas — minimum context.&#10;• Sub-agent context dies with task; no leak into Main history.&#10;• Main never sees sub-agent prompts; it only sees task_board entries.&#10;• report(...) is the ONLY output channel; tool calls are interleaved by orchestrator only." style="rounded=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="540" width="640" height="200" as="geometry" />
        </mxCell>
        <mxCell id="parallel" value="PARALLELISM&#10;Up to 3 sub-agents run concurrently (slots 1,2,3).&#10;If a 4th delegation comes while all are busy:&#10;Main is told via task_board: &quot;queue full&quot; -&gt; will run after one frees, or queue refused with NEEDS_INFO." style="rounded=1;fillColor=#FFF7ED;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="760" width="640" height="160" as="geometry" />
        </mxCell>
        <mxCell id="em1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0F766E;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="m1" target="m2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="em2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#EA580C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="m2" target="m3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="em3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#D97706;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="m3" target="m4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="em4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C2410C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="m3" target="sa">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="esa1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C2410C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="sa" target="sa1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="esa2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C2410C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="sa1" target="sa2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="esa3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C2410C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="sa2" target="sa3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="esa4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C2410C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="sa3" target="sa4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="esa5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#DC2626;dashed=1;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="sa3" target="sa5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eb1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0369A1;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="sa4" target="bus">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eb2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0369A1;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="bus" target="b1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eb3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0369A1;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b1" target="b2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eb4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0369A1;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b2" target="b3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eb5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#16A34A;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b3" target="b4">
          <mxGeometry relative="1" as="geometry" />
