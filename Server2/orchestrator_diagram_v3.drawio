        </mxCell>
        <mxCell id="s11" value="directives.parser eats stream:&#10;plain text -&gt; speak&#10;[DELEGATE …] -&gt; spawn sub-agent (page 7)&#10;[REMEMBER …] -&gt; memory.facts.set(...)&#10;[RECALL …] -&gt; memory.retrieval.query(...) and feed back" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
