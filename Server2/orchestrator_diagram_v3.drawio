  <diagram id="p17" name="17 Full API Map">
    <mxGraphModel dx="2400" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3000" pageHeight="1900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="FULL IMPLEMENTATION API MAP (PLAN.md §7.11)" style="text;html=1;fillColor=none;strokeColor=none;fontColor=#111827;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1400" height="36" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="This page is a function-name index across the whole system: transport, uploads, audio, interrupt, orchestrator, sub-agents, engine, memory, tools, and web client." style="text;html=1;fillColor=none;strokeColor=none;fontColor=#111827;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="58" width="2500" height="28" as="geometry" />
        </mxCell>
        <mxCell id="transport" value="TRANSPORT / PROTOCOL / UPLOAD&#10;ws_endpoint(websocket)&#10;inbound_loop() / outbound_loop()&#10;parse_client_message(raw)&#10;serialize_server_message(msg)&#10;send_json(msg) / send_audio_frame(pcm)&#10;receive_audio_frame(bytes)&#10;upload_file(request, token)&#10;get_uploaded_file(file_id, user_id)&#10;send_client_control(command, reason)&#10;handle_client_state(state)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;align=left;spacingLeft=10;spacingTop=8;fillColor=#DBEAFE;strokeColor=#2563EB;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="500" height="330" as="geometry" />
        </mxCell>
        <mxCell id="voice" value="VOICE / AUDIO / INTERRUPT&#10;STTBackend.transcribe_stream(chunks)&#10;GroqWhisper.transcribe_stream(...)&#10;LocalFasterWhisper.transcribe(...)&#10;KokoroTTS.synthesize_stream(text, voice)&#10;SileroVAD.accept_frame(frame)&#10;InterruptController.handle_interrupt(source)&#10;cancel_tts(turn_id)&#10;cancel_main_decode(turn_id)&#10;drop_partial_utterance(reason)&#10;on_audio_start/chunk/end()" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;align=left;spacingLeft=10;spacingTop=8;fillColor=#CCFBF1;strokeColor=#0F766E;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="120" width="500" height="330" as="geometry" />
        </mxCell>
        <mxCell id="orch" value="ORCHESTRATOR / TASKS&#10;Supervisor.handle_turn(input)&#10;assemble_main_context(input)&#10;stream_main_response(context)&#10;parse_directive_blocks(stream)&#10;validate_directive(directive)&#10;execute_directive(directive)&#10;create_task/pause_task/resume_task&#10;cancel_task/complete_task&#10;TaskBoard.render_for_main()&#10;Notifier.maybe_surface_signal(signal)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;align=left;spacingLeft=10;spacingTop=8;fillColor=#FFF7ED;strokeColor=#C2410C;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1200" y="120" width="500" height="330" as="geometry" />
        </mxCell>
        <mxCell id="subagents" value="SUB-AGENTS&#10;SubAgentWorker.run()&#10;resume_with(message)&#10;checkpoint() / restore(task_id)&#10;parse_report(text) -&gt; ReportSignal&#10;load_capability(name)&#10;render_tool_cards(tools)&#10;report(STEP|NEEDS_INFO|DONE|ERROR)&#10;&#10;Rule: one worker = one task_id; no transport access." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;align=left;spacingLeft=10;spacingTop=8;fillColor=#FFE4E6;strokeColor=#C2410C;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1780" y="120" width="500" height="330" as="geometry" />
        </mxCell>
        <mxCell id="engine" value="ENGINE / PROMPT&#10;start_llama_server()&#10;stop_llama_server()&#10;health_check()&#10;pool.submit(request, priority, slot_hint)&#10;pool.cancel(handle)&#10;reserve_slot(role, task_id)&#10;release_slot(slot_id)&#10;build_main_prompt(context)&#10;build_subagent_prompt(bundle, task)&#10;build_summarizer_prompt(...)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;align=left;spacingLeft=10;spacingTop=8;fillColor=#FDBA74;strokeColor=#9A3412;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="2360" y="120" width="500" height="330" as="geometry" />
        </mxCell>
        <mxCell id="auth" value="AUTH / SESSION&#10;verify_token(token)&#10;get_server1_oauth_token(user_id, provider, scopes)&#10;load_or_create_session(user_id, session_id, client_meta)&#10;persist_session_snapshot(session_state)&#10;Supervisor.attach_transport(transport)&#10;Supervisor.detach_transport(reason)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;align=left;spacingLeft=10;spacingTop=8;fillColor=#FEE2E2;strokeColor=#DC2626;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="540" width="500" height="260" as="geometry" />
        </mxCell>
        <mxCell id="memory" value="MEMORY / FILES / SUMMARIZER&#10;set_fact(key, value, source, confidence)&#10;get_fact(key) / get_chain(key)&#10;build_warm_profile(user_id) / mark_dirty(user_id)&#10;retrieve(query, filters, k)&#10;append_turn(turn) / recent_turns(limit)&#10;compressed_history()&#10;summarize_session(session_id)&#10;extract_facts_from_task(task_id)&#10;summarize_attachment(file_id)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;align=left;spacingLeft=10;spacingTop=8;fillColor=#E0E7FF;strokeColor=#4338CA;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="540" width="500" height="300" as="geometry" />
        </mxCell>
        <mxCell id="tools" value="TOOLS / MCP&#10;ToolRegistry.register(entry)&#10;get(name)&#10;resolve_for_capability(capability, user_id)&#10;search(query, capability, user_id)&#10;ToolRunner.execute(task_id, tool_call)&#10;require_confirmation(tool_call, preview)&#10;verify_confirmation(confirmation_id, tool_call)&#10;load_mcp_servers(config)&#10;mirror_tools()&#10;handle_tools_changed()&#10;tool_search(query, capability?)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;align=left;spacingLeft=10;spacingTop=8;fillColor=#FEF3C7;strokeColor=#CA8A04;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1200" y="540" width="500" height="330" as="geometry" />
        </mxCell>
        <mxCell id="client" value="WEB CLIENT REFERENCE&#10;connect(token)&#10;sendJson(type, payload)&#10;sendPcmFrame(frame)&#10;startMic() / stopMic() / recordOneSecond()&#10;handleServerAudio(frame)&#10;handleClientControl(command)&#10;uploadFile(file) -&gt; UploadedFile&#10;sendChat(text, attachments)&#10;renderEvent(event)&#10;renderTaskBoard(events)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;align=left;spacingLeft=10;spacingTop=8;fillColor=#E0F2FE;strokeColor=#0369A1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1780" y="540" width="500" height="330" as="geometry" />
        </mxCell>
        <mxCell id="rules" value="CROSS-CUTTING RULES&#10;• Binary WS frames = audio only. Files/images use upload_file -&gt; file_id -&gt; chat.attachments.&#10;• Server may request client audio behavior with client_control, but client owns the hardware and confirms with client_state.&#10;• Interrupt cancels Main/TTS/directive buffer only; background sub-agents keep running unless STOP_TASK.&#10;• Main speaks; sub-agents report.&#10;• ToolRunner enforces auth, capability, confirmation, timeout, and audit." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;align=left;spacingLeft=10;spacingTop=8;fillColor=#F8FAFC;strokeColor=#64748B;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="2360" y="540" width="500" height="330" as="geometry" />
        </mxCell>
        <mxCell id="flow1" value="UPLOAD FLOW&#10;user selects image/file -&gt; POST /upload/v1/file -&gt; file_id -&gt; chat.attachments[] -&gt; Supervisor summarizes attachment -&gt; Main decides answer/delegate" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;align=left;spacingLeft=10;spacingTop=8;fillColor=#EFF6FF;strokeColor=#2563EB;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="980" width="760" height="120" as="geometry" />
        </mxCell>
        <mxCell id="flow2" value="AUDIO CONTROL FLOW&#10;Main/TTS starts -&gt; Transport sends audio_start + PCM -&gt; client plays -&gt; interrupt/client_control stop/duck -&gt; client_state confirms -&gt; Supervisor adapts" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;align=left;spacingLeft=10;spacingTop=8;fillColor=#ECFDF5;strokeColor=#0F766E;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1120" y="980" width="760" height="120" as="geometry" />
        </mxCell>
        <mxCell id="flow3" value="TASK COORDINATION FLOW&#10;SubAgentWorker report(...) -&gt; SignalBus -&gt; TaskBoard -&gt; Main active_tasks block -&gt; ANSWER_TO / STOP_TASK / new DELEGATE" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;align=left;spacingLeft=10;spacingTop=8;fillColor=#FFF7ED;strokeColor=#C2410C;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="2080" y="980" width="760" height="120" as="geometry" />
        </mxCell>
        <mxCell id="e_upload" value="file_id" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2563EB;strokeWidth=3;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="transport" target="flow1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_audio" value="PCM + interrupt" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0F766E;strokeWidth=3;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="voice" target="flow2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_task" value="report()" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C2410C;strokeWidth=3;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="subagents" target="flow3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_tool_task" value="ToolResult" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CA8A04;strokeWidth=3;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="tools" target="subagents">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_memory_orch" value="context" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#4338CA;strokeWidth=3;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="memory" target="orch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_engine_orch" value="P0/P1/P2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9A3412;strokeWidth=3;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="orch" target="engine">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_client_transport" value="WS + upload" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0369A1;strokeWidth=3;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="client" target="transport">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
