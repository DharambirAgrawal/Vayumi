  <diagram id="p16" name="16 Coordination + Tool Access">
    <mxGraphModel dx="2400" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2600" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="COORDINATION + TOOL ACCESS CONTRACT (PLAN.md §7.9–§7.10)" style="text;html=1;fillColor=none;strokeColor=none;fontColor=#111827;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1600" height="36" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="One pattern handles NEEDS_INFO, mid-task amendments, confirmations, notes, suggestions, and tool discovery. Main is the only user-facing voice." style="text;html=1;fillColor=none;strokeColor=none;fontColor=#111827;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="58" width="2200" height="26" as="geometry" />
        </mxCell>
        <mxCell id="main_lane" value="MAIN AGENT (slot 0, speaks)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=12;fontColor=#111827;strokeWidth=2;fillColor=#CCFBF1;strokeColor=#0F766E;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="520" height="640" as="geometry" />
        </mxCell>
        <mxCell id="main_ctx" value="Every turn receives:&#10;active_tasks block&#10;recent_completed block&#10;user message / proactive signal&#10;&#10;Main decides:&#10;ask user, answer user, delegate, cancel, or amend task" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#99F6E4;strokeColor=#0F766E;" vertex="1" parent="1">
          <mxGeometry x="70" y="170" width="460" height="180" as="geometry" />
        </mxCell>
        <mxCell id="directives" value="Main directives&#10;[DELEGATE capability=... goal=... payload=...]&#10;[STOP_TASK task_id=...]&#10;[ANSWER_TO task_id=... answer=... mode=reply|amendment]&#10;[RESPOND_VIA chat|voice|both]&#10;[REMEMBER ...] / [RECALL ...]" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#ECFDF5;strokeColor=#0F766E;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="380" width="460" height="210" as="geometry" />
        </mxCell>
        <mxCell id="speak_rule" value="Hard rule&#10;Main is the only component allowed to write chat text or TTS audio. Sub-agents never touch transport." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#FEE2E2;strokeColor=#DC2626;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="620" width="460" height="90" as="geometry" />
        </mxCell>
        <mxCell id="sup_lane" value="SUPERVISOR + TASK BOARD" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=12;fontColor=#111827;strokeWidth=2;fillColor=#FFF7ED;strokeColor=#C2410C;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="610" y="110" width="560" height="640" as="geometry" />
        </mxCell>
        <mxCell id="functions" value="Core functions&#10;Supervisor.handle_turn(input)&#10;spawn_subagent(capability, goal, payload)&#10;apply_answer_to_task(task_id, answer, mode)&#10;TaskBoard.upsert_from_signal(signal)&#10;TaskBoard.render_for_main()" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#FED7AA;strokeColor=#C2410C;" vertex="1" parent="1">
          <mxGeometry x="640" y="170" width="500" height="210" as="geometry" />
        </mxCell>
        <mxCell id="states" value="Task statuses&#10;running · blocked · paused · waiting_user · done · error · cancelled&#10;&#10;All keyed by task_id. Supervisor is the only writer of task_board." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#FFEDD5;strokeColor=#C2410C;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="410" width="500" height="140" as="geometry" />
        </mxCell>
        <mxCell id="bus" value="SignalBus&#10;report(STEP|NEEDS_INFO|DONE|ERROR)&#10;→ PG audit row&#10;→ task_board update&#10;→ optional notifier synthetic turn" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#F3E8FF;strokeColor=#7C3AED;" vertex="1" parent="1">
          <mxGeometry x="640" y="580" width="500" height="130" as="geometry" />
        </mxCell>
        <mxCell id="worker_lane" value="SUB-AGENT WORKER (one task_id)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=12;fontColor=#111827;strokeWidth=2;fillColor=#FFE4E6;strokeColor=#C2410C;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1220" y="110" width="560" height="640" as="geometry" />
        </mxCell>
        <mxCell id="worker_api" value="Worker API&#10;SubAgentWorker.run()&#10;resume_with(message)&#10;pause(question, payload)&#10;cancel(reason)&#10;&#10;Worker owns one transcript and checkpoints it. If KV is lost, replay transcript to resume logical state." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#FED7AA;strokeColor=#C2410C;" vertex="1" parent="1">
          <mxGeometry x="1250" y="170" width="500" height="210" as="geometry" />
        </mxCell>
        <mxCell id="reports" value="report() meanings&#10;STEP: progress only&#10;NEEDS_INFO: pause + ask user&#10;DONE: summary + artifacts + facts + optional note/suggestion&#10;ERROR: retry or surface if user-actionable" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#FEE2E2;strokeColor=#DC2626;" vertex="1" parent="1">
          <mxGeometry x="1250" y="410" width="500" height="160" as="geometry" />
        </mxCell>
        <mxCell id="cases" value="Five cases collapse here&#10;1 needs more info&#10;2 user adds context while running&#10;3 tool confirmation&#10;4 note_for_agent after DONE&#10;5 suggestion after DONE" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#FFF7ED;strokeColor=#C2410C;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1250" y="600" width="500" height="120" as="geometry" />
        </mxCell>
        <mxCell id="tool_lane" value="TOOL ACCESS + DISCOVERY" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=12;fontColor=#111827;strokeWidth=2;fillColor=#FEF3C7;strokeColor=#CA8A04;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1830" y="110" width="700" height="640" as="geometry" />
        </mxCell>
        <mxCell id="toolentry" value="ToolEntry&#10;name · capability · description · args_schema · result_schema&#10;requires_auth · requires_confirmation · risk · cost_hint · timeout_s&#10;&#10;Registry enforces capability access before any function runs." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#FDE68A;strokeColor=#CA8A04;" vertex="1" parent="1">
          <mxGeometry x="1860" y="170" width="640" height="170" as="geometry" />
        </mxCell>
        <mxCell id="toolresult" value="ToolResult.status&#10;ok&#10;confirmation_required&#10;user_action_required&#10;not_capable&#10;error&#10;&#10;ToolRunner normalizes every native/MCP result to this shape." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#FFFBEB;strokeColor=#CA8A04;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1860" y="370" width="300" height="230" as="geometry" />
        </mxCell>
        <mxCell id="toolsearch" value="tool_search(query, capability?)&#10;Returns compact ToolCards, not full schemas.&#10;Main uses it to decide capability/delegation.&#10;Sub-agents use it only inside their allowed capability slice." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#DBEAFE;strokeColor=#2563EB;" vertex="1" parent="1">
          <mxGeometry x="2190" y="370" width="310" height="230" as="geometry" />
        </mxCell>
        <mxCell id="confirm" value="Confirmation loop&#10;Tool returns confirmation_required&#10;→ worker report(NEEDS_INFO, payload.confirmation)&#10;→ Main asks user&#10;→ [ANSWER_TO task_id=... confirmed=true]&#10;→ ToolRunner verifies confirmation id/hash&#10;→ action executes" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#FEE2E2;strokeColor=#DC2626;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1860" y="630" width="640" height="100" as="geometry" />
        </mxCell>
        <mxCell id="flow_needs" value="NEEDS_INFO FLOW&#10;Sub-agent: report(NEEDS_INFO, question) → task paused → Main asks → user answers → [ANSWER_TO task_id=x answer=...] → resume_with(answer)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#F8FAFC;strokeColor=#64748B;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="820" width="780" height="120" as="geometry" />
        </mxCell>
        <mxCell id="flow_amend" value="MID-TASK AMENDMENT FLOW&#10;User adds context while task is running → Main sees active_tasks → [ANSWER_TO task_id=x mode=amendment] → worker receives next message and adjusts." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#F8FAFC;strokeColor=#64748B;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="870" y="820" width="780" height="120" as="geometry" />
        </mxCell>
        <mxCell id="flow_done" value="DONE NOTE / SUGGESTION FLOW&#10;Sub-agent: report(DONE, payload.note_for_agent / suggestion) → Main decides whether to surface → if user says yes, Main delegates a new task." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#F8FAFC;strokeColor=#64748B;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1700" y="820" width="780" height="120" as="geometry" />
        </mxCell>
        <mxCell id="e_main_sup" value="validated directives" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0F766E;strokeWidth=3;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="directives" target="functions">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_sup_worker" value="spawn / resume / cancel" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C2410C;strokeWidth=3;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="functions" target="worker_api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_worker_bus" value="report(...)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7C3AED;strokeWidth=3;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="reports" target="bus">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_bus_main" value="task_board block" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7C3AED;strokeWidth=3;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="bus" target="main_ctx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
