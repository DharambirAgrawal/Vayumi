      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p13" name="13 Real Scenarios">
    <mxGraphModel dx="2400" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" value="REAL SCENARIOS — what the user sees vs what happens server-side" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sa" value="A) WAKE + SIMPLE QUERY (Bitcoin price)" style="rounded=1;fillColor=#E8F5E9;strokeColor=#16A34A;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="2320" height="180" as="geometry" />
        </mxCell>
        <mxCell id="a1" value="USER&#10;'Hey Vayumi, what is bitcoin price?'" style="rounded=1;fillColor=#DCFCE7;strokeColor=#388E3C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="Main: ack 'Checking now.'&#10;direct tool web_search via main bundle (no sub-agent)" style="rounded=1;fillColor=#99F6E4;strokeColor=#0F766E;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="460" y="160" width="440" height="100" as="geometry" />
        </mxCell>
        <mxCell id="a3" value="Tavily query -&gt; top result" style="rounded=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="920" y="160" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="a4" value="Main TTS: 'Around $X according to … Want 24h range?'" style="rounded=1;fillColor=#99F6E4;strokeColor=#0F766E;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1320" y="160" width="500" height="100" as="geometry" />
        </mxCell>
        <mxCell id="a5" value="Memory writes: NONE (transient)&#10;Total time: ~1.5s" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1840" y="160" width="500" height="100" as="geometry" />
        </mxCell>
        <mxCell id="sb" value="B) URL SUMMARY (sub-agent path)" style="rounded=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="2320" height="200" as="geometry" />
        </mxCell>
        <mxCell id="b1" value="USER (chat)&#10;'summarize this URL in 5 bullets'" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="360" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="b2" value="Main writes [DELEGATE capability=research goal=… payload={url}]&#10;Main tells user: 'Got it — reading and summarizing now.'" style="rounded=1;fillColor=#99F6E4;strokeColor=#0F766E;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="460" y="360" width="500" height="120" as="geometry" />
        </mxCell>
        <mxCell id="b3" value="Sub-agent (slot 1)&#10;fetch_html -&gt; trafilatura -&gt; chunk -&gt; per-chunk LLM summary -&gt; merge&#10;reports STEP, then DONE with 5 bullets payload" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="980" y="360" width="540" height="120" as="geometry" />
        </mxCell>
        <mxCell id="b4" value="Notifier (user idle) surfaces:&#10;Main: 'Done — here are the 5 bullets …'" style="rounded=1;fillColor=#99F6E4;strokeColor=#0F766E;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1540" y="360" width="500" height="120" as="geometry" />
        </mxCell>
        <mxCell id="b5" value="LanceDB doc_chunks stored under doc_id&#10;future follow-up reuses [RECALL doc:…] without re-fetch" style="rounded=1;fillColor=#A5B4FC;strokeColor=#4338CA;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="2060" y="360" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="sc" value="C) MULTI-STEP TASK WITH PARALLEL SUB-AGENTS" style="rounded=1;fillColor=#F5F3FF;strokeColor=#7C3AED;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="520" width="2320" height="240" as="geometry" />
        </mxCell>
        <mxCell id="c1" value="USER (voice)&#10;'Plan a vendor migration, compare 3 options, draft a stakeholder update'" style="rounded=1;fillColor=#E9D5FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="580" width="380" height="160" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="Main builds task graph:&#10;• r1: research vendors (research)&#10;• r2: stakeholder draft (productivity)&#10;writes [DELEGATE r1] then [DELEGATE r2]&#10;says: 'On it — research and a draft, in parallel.'" style="rounded=1;fillColor=#99F6E4;strokeColor=#0F766E;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="460" y="580" width="500" height="160" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="r1 in slot 1, r2 in slot 2 (parallel decode in llama-server)&#10;both stream STEPs into signal bus" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="980" y="580" width="500" height="160" as="geometry" />
        </mxCell>
        <mxCell id="c4" value="r2 NEEDS_INFO: 'what tone — formal or casual?'&#10;Notifier surfaces only that question to user&#10;r1 keeps running" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1500" y="580" width="500" height="160" as="geometry" />
        </mxCell>
        <mxCell id="c5" value="user replies; r2 resumes&#10;both DONE -&gt; Main merges -&gt; one coherent reply with both outputs&#10;memory write: vendor comparison fact + draft saved" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="2020" y="580" width="320" height="160" as="geometry" />
        </mxCell>
        <mxCell id="sd" value="D) MEMORY UPDATE + HISTORICAL QUERY" style="rounded=1;fillColor=#E0E7FF;strokeColor=#4338CA;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="780" width="2320" height="220" as="geometry" />
        </mxCell>
        <mxCell id="d1" value="USER&#10;'my name is Alexei now'" style="rounded=1;fillColor=#C7D2FE;strokeColor=#4338CA;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="840" width="380" height="140" as="geometry" />
        </mxCell>
        <mxCell id="d2" value="Main writes [REMEMBER key=name value='Alexei' source=user_intent]&#10;Main says: 'Got it — I'll call you Alexei from now on.'" style="rounded=1;fillColor=#99F6E4;strokeColor=#0F766E;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="460" y="840" width="540" height="140" as="geometry" />
        </mxCell>
        <mxCell id="d3" value="memory.facts.set('name','Alexei',...)&#10;old row -&gt; active=false, superseded_by=NEW&#10;warm.dirty=True (rebuilt next turn)" style="rounded=1;fillColor=#A5B4FC;strokeColor=#4338CA;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1020" y="840" width="500" height="140" as="geometry" />
        </mxCell>
        <mxCell id="d4" value="Hours later, USER:&#10;'what was my name before?'&#10;Main: [RECALL chain key=name]&#10;orchestrator returns [Alexei (active), Alex (superseded 2026-05-09)]&#10;Main says: 'You used to be Alex.'" style="rounded=1;fillColor=#99F6E4;strokeColor=#0F766E;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1540" y="840" width="540" height="140" as="geometry" />
        </mxCell>
        <mxCell id="d5" value="ZERO context cost on every other turn" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontStyle=1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="2100" y="840" width="240" height="140" as="geometry" />
        </mxCell>
        <mxCell id="se" value="E) INTERRUPT MID-RESPONSE (parallel tasks survive)" style="rounded=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="1020" width="2320" height="220" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="AI is mid-sentence reading bullets" style="rounded=1;fillColor=#99F6E4;strokeColor=#0F766E;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="1080" width="380" height="140" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="USER says 'Vayumi, stop'&#10;wake-word triggers interrupt {source:wake}" style="rounded=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="460" y="1080" width="500" height="140" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="TTS stops within 100ms&#10;slot 0 inference cancelled&#10;directive buffer cleared (no ghost task)" style="rounded=1;fillColor=#99F6E4;strokeColor=#0F766E;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="980" y="1080" width="540" height="140" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="Sub-agent r1 in slot 1 KEEPS WORKING&#10;Summarizer in slot 3 KEEPS WORKING" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1540" y="1080" width="500" height="140" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="When user is silent again,&#10;notifier surfaces r1 DONE." style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="2060" y="1080" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="sf" value="F) DEVICE HANDOFF (web start, mobile continue)" style="rounded=1;fillColor=#FFF7ED;strokeColor=#C2410C;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="1260" width="2320" height="180" as="geometry" />
        </mxCell>
        <mxCell id="f1" value="user starts r1 (research) on web&#10;closes laptop" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="1320" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="f2" value="WS closes; Supervisor lingers 60s, then writes session.disconnected=now()&#10;r1 keeps running on llama-server slot 1; reports to PG signals + Redis" style="rounded=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="460" y="1320" width="540" height="100" as="geometry" />
        </mxCell>
        <mxCell id="f3" value="user opens mobile app&#10;mobile sends hello {session_id: same}&#10;Server reattaches Supervisor or rebuilds from PG state" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1020" y="1320" width="540" height="100" as="geometry" />
        </mxCell>
        <mxCell id="f4" value="r1 has finished -&gt; Server 1 push notification was sent;&#10;mobile shows it; user taps it -&gt; full conversation continues with r1 result already merged into context" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1580" y="1320" width="760" height="100" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p14" name="14 Step 01 Build Slice">
    <mxGraphModel dx="2200" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" value="STEP 01 — PROJECT SCAFFOLD + WEBSOCKET ECHO" style="text;html=1;fontSize=22;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1200" height="34" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="This page is the implementation slice from doc/step-01.md: prove auth + transport + storage boot before adding LLM, STT, TTS, memory, or tools." style="text;html=1;fontSize=12;fillColor=none;strokeColor=none;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="40" y="58" width="1600" height="28" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="READING KEY&#10;Thick solid arrows = runtime path to prove in Step 01. Dashed arrows = startup dependency checks. Red = reject/close. Green = acceptance test passes." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#F8FAFC;strokeColor=#64748B;" vertex="1" parent="1">
          <mxGeometry x="1510" y="80" width="560" height="110" as="geometry" />
        </mxCell>
        <mxCell id="out" value="OUT OF SCOPE IN STEP 01&#10;No LLM · no llama-server · no STT/TTS · no VAD · no wake word · no memory behavior · no tools/sub-agents." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=11;fontColor=#111827;strokeWidth=2;fillColor=#FEE2E2;strokeColor=#DC2626;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1510" y="220" width="560" height="120" as="geometry" />
        </mxCell>
        <mxCell id="client" value="WEB CLIENT /&#10;index.html + client.js&#10;&#10;Token input&#10;Connect button&#10;Typed chat send&#10;Record 1s PCM&#10;Scrolling log" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=12;fontColor=#111827;strokeWidth=2;fillColor=#DBEAFE;strokeColor=#2563EB;" vertex="1" parent="1">
          <mxGeometry x="70" y="160" width="300" height="310" as="geometry" />
        </mxCell>
        <mxCell id="ws" value="FastAPI WebSocket&#10;/ws/v1/session?token=&amp;lt;jwt&amp;gt;&#10;&#10;Accepts JSON frames&#10;Accepts binary PCM frames&#10;Echoes both for Step 01" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=12;fontColor=#111827;strokeWidth=2;fillColor=#F5F3FF;strokeColor=#6D28D9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="160" width="360" height="310" as="geometry" />
        </mxCell>
        <mxCell id="auth" value="auth.py&#10;verify_token(token)&#10;&#10;Decode RS256 JWT&#10;Validate exp/iat/sub/sid/jti&#10;Check Server 1 Redis blocklist" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fontSize=12;fontColor=#111827;strokeWidth=2;fillColor=#FFE4E6;strokeColor=#BE123C;" vertex="1" parent="1">
