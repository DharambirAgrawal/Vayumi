  <diagram id="p01" name="01 System Overview">
    <mxGraphModel dx="2400" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="VAYUMI — END-TO-END SYSTEM OVERVIEW (locked plan v1.1)" style="text;html=1;fontSize=22;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1400" height="36" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="One WS session protocol + upload endpoint, three client types, one llama-server engine with 4 slots, hand-rolled supervisor. Solid lines = sync data path. Dashed = async / on-demand." style="text;html=1;fontSize=12;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="58" width="1900" height="22" as="geometry" />
        </mxCell>
        <mxCell id="bg_clients" value="CLIENTS (interchangeable, same WS protocol)" style="rounded=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="520" height="640" as="geometry" />
        </mxCell>
        <mxCell id="cl_web" value="Web client&#10;(vanilla JS, AudioWorklet, MediaSession)" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="70" y="160" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cl_app" value="Mobile app&#10;(React Native or Flutter, native PCM socket)" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="70" y="240" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cl_hw" value="ESP32 smart speaker&#10;(esp_websocket_client, hardware AEC)" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="70" y="320" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cl_responsibility" value="Client owns:&#10;• mic capture (16 kHz mono PCM)&#10;• echo cancellation (browser flag / OS / hw chip)&#10;• wake-word detection (openWakeWord ONNX)&#10;• playback + captions UI&#10;• tap-to-interrupt button" style="rounded=1;fillColor=#E0F2FE;strokeColor=#0369A1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="70" y="410" width="460" height="160" as="geometry" />
        </mxCell>
        <mxCell id="cl_protocol" value="WS session protocol + upload endpoint&#10;Binary WS = PCM audio only | JSON = session/control | Upload = files/images" style="rounded=1;fillColor=#FEF08A;strokeColor=#CA8A04;fontStyle=1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="70" y="600" width="460" height="120" as="geometry" />
        </mxCell>
        <mxCell id="bg_s1" value="SERVER 1 (auth, identity)" style="rounded=1;fillColor=#FFE4E6;strokeColor=#BE123C;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="780" width="520" height="240" as="geometry" />
        </mxCell>
        <mxCell id="s1_role" value="Issues RS256 JWT (access + refresh)&#10;Maintains user accounts, sessions, blocklist&#10;TypeScript / Express / Postgres / Redis" style="rounded=1;fillColor=#FECDD3;strokeColor=#BE123C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="70" y="840" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s1_handoff" value="Handoff to Server 2:&#10;1) shared RS256 public key&#10;2) shared Redis blocklist (jti)" style="rounded=1;fillColor=#FDA4AF;strokeColor=#BE123C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="70" y="930" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="bg_s2" value="SERVER 2 — VAYUMI ORCHESTRATION (this plan)" style="rounded=1;fillColor=#F5F3FF;strokeColor=#7C3AED;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="100" width="1300" height="1240" as="geometry" />
        </mxCell>
        <mxCell id="t_transport" value="TRANSPORT plane (FastAPI + WS)&#10;auth handshake · envelope codec · ingress/egress framing · heartbeat" style="rounded=1;fillColor=#DDD6FE;strokeColor=#6D28D9;fontStyle=1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="630" y="160" width="1240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="t_voice" value="VOICE plane&#10;STT (Groq Whisper / faster-whisper) · Kokoro TTS · Silero VAD · interrupt SM" style="rounded=1;fillColor=#CCFBF1;strokeColor=#0F766E;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="630" y="250" width="600" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t_orch" value="ORCHESTRATOR plane (the supervisor)&#10;directives · signal bus · task board · proactive notifier" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontStyle=1;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1250" y="250" width="620" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t_engine" value="ENGINE plane&#10;llama-server subprocess · 4 parallel slots · priority queue (P0/P1/P2)" style="rounded=1;fillColor=#FDBA74;strokeColor=#9A3412;fontStyle=1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="630" y="350" width="1240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="t_main" value="MAIN AGENT (slot 0, sticky)&#10;owns speech, parses directives, talks to user" style="rounded=1;fillColor=#99F6E4;strokeColor=#0F766E;fontStyle=1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="630" y="440" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="t_subs" value="SUB-AGENTS (slot 1..N, ephemeral)&#10;capability-scoped tools · report() only · no speaking" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1030" y="440" width="450" height="100" as="geometry" />
        </mxCell>
        <mxCell id="t_sum" value="SUMMARIZER (slot N, P2)&#10;compression + fact extraction&#10;runs in idle gaps" style="rounded=1;fillColor=#E9D5FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1500" y="440" width="370" height="100" as="geometry" />
        </mxCell>
        <mxCell id="t_tools" value="TOOL plane&#10;Native Python registry · MCP adapter · capability bundles (research, productivity, comms, data)" style="rounded=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="630" y="560" width="1240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t_mem" value="MEMORY plane&#10;Postgres versioned facts · LanceDB embedded retrieval · warm profile · session history · summarizer pipeline" style="rounded=1;fillColor=#A5B4FC;strokeColor=#4338CA;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="630" y="660" width="1240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t_data" value="DATA stores (the only places state lives)" style="rounded=1;fillColor=#C7D2FE;strokeColor=#4338CA;fontStyle=1;fontSize=12;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="630" y="780" width="1240" height="40" as="geometry" />
        </mxCell>
        <mxCell id="t_pg" value="Postgres (Supabase or self-host)&#10;facts (versioned), sessions, conversations,&#10;turns, tasks, signals (audit), settings" style="rounded=1;fillColor=#C7D2FE;strokeColor=#4338CA;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="640" y="830" width="400" height="120" as="geometry" />
        </mxCell>
        <mxCell id="t_redis" value="Redis (shared with Server 1)&#10;JWT blocklist (jti) [read]&#10;signal bus pub/sub [own]&#10;rate-limit + ephemeral [own]" style="rounded=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1060" y="830" width="380" height="120" as="geometry" />
        </mxCell>
