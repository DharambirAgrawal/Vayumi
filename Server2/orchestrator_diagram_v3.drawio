        </mxCell>
        <mxCell id="s3" value="ws.inbound_loop forwards chunks to&#10;Supervisor.on_audio_chunk" style="rounded=1;fillColor=#DDD6FE;strokeColor=#6D28D9;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="450" y="230" width="280" height="80" as="geometry" />
        </mxCell>
