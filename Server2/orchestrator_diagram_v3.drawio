        </mxCell>
        <mxCell id="s10" value="engine.pool.submit(P0, slot=0, prompt, stream=True)&#10;tokens stream back to Supervisor" style="rounded=1;fillColor=#FDBA74;strokeColor=#9A3412;fontStyle=1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
