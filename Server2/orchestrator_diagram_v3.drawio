      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p08" name="08 Tools &amp; MCP">
    <mxGraphModel dx="2200" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" value="TOOL PLANE — registry, capability bundles, MCP adapter" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="Goal: adding a tool is 5 lines. Adding a whole MCP server (Notion, GitHub, gmail, anything) is one entry in mcp.json." style="text;html=1;fontSize=12;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="56" width="1500" height="22" as="geometry" />
        </mxCell>
        <mxCell id="reg" value="REGISTRY (server/tools/registry.py)" style="rounded=1;fillColor=#FEF3C7;strokeColor=#CA8A04;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="700" height="600" as="geometry" />
        </mxCell>
        <mxCell id="reg_struct" value="ToolEntry (typed, immutable)&#10;• name: str (unique)&#10;• fn: async Callable[..., ToolResult]&#10;• args_schema: JSONSchema&#10;• result_schema?: JSONSchema&#10;• capability: main|research|productivity|comms|data&#10;• requires_auth: bool&#10;• requires_confirmation: bool&#10;• risk: read|write|send|delete|purchase&#10;• cost_hint: cheap|net|heavy" style="rounded=1;fillColor=#FDE68A;strokeColor=#CA8A04;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="660" height="230" as="geometry" />
        </mxCell>
        <mxCell id="reg_native" value="NATIVE TOOLS (Phase 1+)&#10;• web_search (Tavily/DDG)&#10;• summarize_url (trafilatura + sub-agent)&#10;• fetch_html (raw)&#10;• memory_save / memory_recall&#10;• calculator&#10;• datetime helpers" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="380" width="320" height="180" as="geometry" />
        </mxCell>
        <mxCell id="reg_user" value="USER-INTEGRATION TOOLS (Phase 3)&#10;• gmail.read / send&#10;• calendar.create&#10;• notion.append_block&#10;• drive.list / fetch&#10;all use credentials from Server-1 oauth_integrations" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="400" y="380" width="320" height="180" as="geometry" />
        </mxCell>
        <mxCell id="reg_router" value="capability_router.py&#10;maps Capability -&gt; list[ToolEntry]&#10;sub-agent ONLY sees its capability slice" style="rounded=1;fillColor=#FDBA74;strokeColor=#9A3412;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="580" width="660" height="100" as="geometry" />
        </mxCell>
        <mxCell id="add" value="ADDING A TOOL — 5 LINES" style="rounded=1;fillColor=#E8F5E9;strokeColor=#16A34A;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="720" width="700" height="350" as="geometry" />
        </mxCell>
        <mxCell id="add_steps" value="1) tools/get_weather.py&#10;async def get_weather(city: str) -&gt; str: ...&#10;&#10;2) JSON schema in same file&#10;SCHEMA = {'name': 'get_weather', 'parameters': {...}}&#10;&#10;3) tools/__init__.py&#10;register(get_weather, SCHEMA, capability='data', cost='net')&#10;&#10;4) (optional) skills/get_weather.md&#10;multi-step instructions injected only if sub-agent uses this tool&#10;&#10;5) DONE — main never sees it; only data-capability sub-agents do." style="rounded=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=11;fontFamily=Courier New;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="780" width="660" height="280" as="geometry" />
        </mxCell>
        <mxCell id="mcp" value="MCP ADAPTER (server/tools/mcp_adapter.py)" style="rounded=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="780" y="100" width="700" height="500" as="geometry" />
        </mxCell>
        <mxCell id="mcp1" value="MCP_SERVERS_JSON declares servers&#10;[{name:'fs', transport:'stdio', command:['npx', '-y', '@modelcontextprotocol/server-filesystem']},&#10; {name:'notion', transport:'http', url:'https://...'}]" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="800" y="160" width="660" height="120" as="geometry" />
        </mxCell>
        <mxCell id="mcp2" value="On boot:&#10;• connect each MCP server (Python SDK)&#10;• list_tools() -&gt; for each, build a ToolEntry that&#10;  forwards to client.call_tool()&#10;• capability is config-mapped (default: 'data')&#10;• subscribe to tools/list_changed notifications -&gt; live re-mirror" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="800" y="300" width="660" height="160" as="geometry" />
        </mxCell>
        <mxCell id="mcp3" value="Result: any MCP-compatible service is now an in-process Python tool.&#10;Same call shape, same registry, same capability gating." style="rounded=1;fillColor=#90CAF9;strokeColor=#1565C0;fontStyle=1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="800" y="480" width="660" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ux" value="TOOL UX CONTRACT (client-facing)" style="rounded=1;fillColor=#FFF7ED;strokeColor=#C2410C;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="780" y="620" width="700" height="450" as="geometry" />
        </mxCell>
        <mxCell id="ux1" value="1) ANNOUNCE INTENT&#10;before each 'heavy' tool call (cost!=cheap),&#10;Main writes a short user-visible line:&#10;'Checking the price now.'" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="800" y="680" width="660" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ux2" value="2) EVENT FEED&#10;event{kind:'tool_started', name, task_id, summary}&#10;event{kind:'tool_done', name, task_id, latency_ms}&#10;client renders an activity feed (separate from chat bubbles)" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="800" y="800" width="660" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ux3" value="3) FAILURE COMMUNICATION&#10;tool failure -&gt; sub-agent reports ERROR&#10;Main says: 'X failed because …; want me to try Y?'&#10;Never silent failure." style="rounded=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="800" y="940" width="660" height="120" as="geometry" />
        </mxCell>
        <mxCell id="cap_grid" value="CAPABILITY -&gt; TOOLS MAP (default; configurable)" style="rounded=1;fillColor=#F5F3FF;strokeColor=#7C3AED;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1520" y="100" width="630" height="970" as="geometry" />
        </mxCell>
        <mxCell id="cap_research" value="research&#10;web_search · fetch_html · summarize_url · memory_recall" style="rounded=1;fillColor=#F3E8FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1540" y="160" width="600" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cap_prod" value="productivity&#10;notion.* · drive.* · calendar.create · file.write_local" style="rounded=1;fillColor=#F3E8FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1540" y="260" width="600" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cap_comms" value="comms&#10;gmail.read · gmail.send · calendar.read · contacts.lookup" style="rounded=1;fillColor=#F3E8FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1540" y="360" width="600" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cap_data" value="data&#10;weather · stock · price · http.get/post · MCP-imported" style="rounded=1;fillColor=#F3E8FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1540" y="460" width="600" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cap_main" value="main (Main Agent direct, fast tools only)&#10;memory_save · memory_recall · web_search · datetime · calculator" style="rounded=1;fillColor=#99F6E4;strokeColor=#0F766E;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1540" y="560" width="600" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cap_rule" value="RULE&#10;Main sees CAPABILITY LABELS not full tool schemas of sub-agents.&#10;Main directly calls only the 'main' bundle (cheap+predictable).&#10;Anything heavier -&gt; [DELEGATE capability=…]." style="rounded=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1540" y="660" width="600" height="180" as="geometry" />
        </mxCell>
        <mxCell id="ce1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2563EB;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="mcp1" target="mcp2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2563EB;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="mcp2" target="reg_native">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7C3AED;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="reg_router" target="cap_research">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p09" name="09 Memory model">
    <mxGraphModel dx="2200" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" value="MEMORY MODEL — three layers, four write sources, versioned facts" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="L" value="LAYERS" style="rounded=1;fillColor=#E0E7FF;strokeColor=#4338CA;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="660" height="1240" as="geometry" />
        </mxCell>
        <mxCell id="l1" value="L1 — WARM PROFILE (always in context)&#10;~600 tokens&#10;name, pronouns, comm style, top contacts, top preferences&#10;rebuilt only when warm.dirty=True (next turn start)&#10;source: memory.warm.build() reads only ACTIVE versioned facts" style="rounded=1;fillColor=#A5B4FC;strokeColor=#4338CA;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="620" height="170" as="geometry" />
        </mxCell>
        <mxCell id="l2" value="L2 — ON-DEMAND RETRIEVAL (LanceDB)&#10;semantic top-k by query embedding (bge-small)&#10;tables: facts_index, session_history, meeting_chunks, doc_chunks&#10;triggered only by [RECALL …] directive or memory_recall tool&#10;NEVER auto-injected per turn" style="rounded=1;fillColor=#C7D2FE;strokeColor=#4338CA;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="330" width="620" height="170" as="geometry" />
        </mxCell>
        <mxCell id="l3" value="L3 — VERSIONED FACT STORE (Postgres)&#10;ground truth; all reads/writes pass through here&#10;structure: (key, value, active, created_at, superseded_by, source)&#10;active row used by warm; superseded chain used for 'what was X before?'" style="rounded=1;fillColor=#A5B4FC;strokeColor=#4338CA;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="520" width="620" height="170" as="geometry" />
        </mxCell>
        <mxCell id="l_ses" value="SESSION HISTORY (Postgres + LanceDB)&#10;rolling raw turns + compressed summaries&#10;recent N turns kept verbatim for warm context&#10;older turns -&gt; summarizer -&gt; LanceDB (recall via L2)" style="rounded=1;fillColor=#C7D2FE;strokeColor=#4338CA;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="710" width="620" height="160" as="geometry" />
        </mxCell>
        <mxCell id="l_meet" value="MEETING TRANSCRIPTS (LanceDB)&#10;diarized chunks; queryable by time and speaker&#10;summary is also a fact under key=meeting:&lt;date&gt;:summary" style="rounded=1;fillColor=#C7D2FE;strokeColor=#4338CA;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="890" width="620" height="120" as="geometry" />
        </mxCell>
        <mxCell id="l_doc" value="DOC CHUNKS (LanceDB)&#10;long-input pastes / attached PDFs&#10;chunked + embedded; usable by research sub-agent" style="rounded=1;fillColor=#C7D2FE;strokeColor=#4338CA;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="1030" width="620" height="120" as="geometry" />
        </mxCell>
        <mxCell id="l_warm_rule" value="RULE: only L1 enters context on every turn. L2/L3 enter only if asked." style="rounded=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="1170" width="620" height="60" as="geometry" />
        </mxCell>
        <mxCell id="W" value="WRITE SOURCES (the only ways facts get saved)" style="rounded=1;fillColor=#FFF7ED;strokeColor=#C2410C;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="720" y="80" width="660" height="1240" as="geometry" />
        </mxCell>
        <mxCell id="w1" value="A) Main agent direct&#10;[REMEMBER key=…, value=…, source='user_intent']&#10;parsed only from explicit user-ask:&#10;'remember my address is …'" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="740" y="140" width="620" height="120" as="geometry" />
        </mxCell>
        <mxCell id="w2" value="B) Sub-agent task DONE&#10;Summarizer reads result_summary -&gt; extract candidate facts&#10;LLM-judge filter: stable, &gt;= confidence threshold, not duplicate&#10;writes via memory.facts.set()" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="740" y="280" width="620" height="120" as="geometry" />
        </mxCell>
        <mxCell id="w3" value="C) History compression&#10;Summarizer compresses oldest N turns&#10;extracts stable facts from compressed block" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="740" y="420" width="620" height="100" as="geometry" />
        </mxCell>
        <mxCell id="w4" value="D) User-explicit on UI&#10;client emits chat 'please remember X'&#10;same path as A but flagged source='user_command'" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="740" y="540" width="620" height="100" as="geometry" />
        </mxCell>
        <mxCell id="set" value="memory.facts.set(key, value, source)" style="rounded=1;fillColor=#FDBA74;strokeColor=#9A3412;fontStyle=1;fontSize=12;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="740" y="660" width="620" height="50" as="geometry" />
        </mxCell>
        <mxCell id="set_steps" value="1) BEGIN tx&#10;2) SELECT current active row WHERE key=K AND active=true&#10;3) UPDATE that row SET active=false, superseded_at=now(), superseded_by=NEW_ID&#10;4) INSERT new row {id:NEW_ID, key, value, active=true, source, created_at}&#10;5) re-embed value -&gt; upsert into LanceDB facts_index&#10;6) if key in WARM_KEYS -&gt; warm.dirty=True&#10;7) COMMIT" style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;fontFamily=Courier New;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="740" y="730" width="620" height="200" as="geometry" />
        </mxCell>
        <mxCell id="readbox" value="memory.facts.get(key) -&gt; value | None&#10;memory.facts.chain(key) -&gt; [active, prev, prev_prev, …]" style="rounded=1;fillColor=#C5E1A5;strokeColor=#558B2F;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="740" y="950" width="620" height="80" as="geometry" />
        </mxCell>
        <mxCell id="hist_q" value="Historical query example&#10;User: 'what was my old address?'&#10;-&gt; Main directive [RECALL chain key='address']&#10;-&gt; orchestrator runs facts.chain('address')&#10;-&gt; result fed back as RECALL_RESULT into next inference" style="rounded=1;fillColor=#DCEDC8;strokeColor=#689F38;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="740" y="1050" width="620" height="160" as="geometry" />
        </mxCell>
        <mxCell id="S" value="STORAGE LAYOUT" style="rounded=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1400" y="80" width="700" height="1240" as="geometry" />
        </mxCell>
        <mxCell id="pg_facts" value="PG facts (versioned)&#10;id UUID, user_id, key TEXT, value JSONB, active BOOL,&#10;source TEXT, confidence FLOAT, created_at, superseded_at,&#10;superseded_by UUID&#10;UNIQUE(user_id, key) WHERE active=true&#10;INDEX (user_id, key, active), (user_id, created_at DESC)" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;fontFamily=Courier New;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1420" y="140" width="660" height="180" as="geometry" />
        </mxCell>
        <mxCell id="pg_sessions" value="PG sessions / conversations / turns / tasks / signals" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1420" y="340" width="660" height="60" as="geometry" />
        </mxCell>
        <mxCell id="pg_settings" value="PG user_runtime_settings&#10;voice prefs, mode, do_not_disturb windows" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1420" y="420" width="660" height="80" as="geometry" />
        </mxCell>
        <mxCell id="lance_idx" value="LanceDB tables&#10;facts_index   (id, user_id, key, value_text, embedding[384])&#10;session_history (turn_id, user_id, role, text, embedding)&#10;meeting_chunks (chunk_id, meeting_id, speaker, ts, text, embedding)&#10;doc_chunks    (chunk_id, doc_id, text, embedding, meta)" style="rounded=1;fillColor=#FECDD3;strokeColor=#BE123C;fontSize=11;fontColor=#111827;fontFamily=Courier New;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1420" y="520" width="660" height="180" as="geometry" />
        </mxCell>
        <mxCell id="redis_mem" value="Redis (ephemeral memory)&#10;warm_cache:&lt;user_id&gt; -&gt; built warm block (TTL 10m)&#10;signal_bus:&lt;session_id&gt; -&gt; pub/sub channel" style="rounded=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1420" y="720" width="660" height="120" as="geometry" />
        </mxCell>
        <mxCell id="rules_mem" value="GUARANTEES&#10;• no silent overwrite — every change creates a new row + supersedes the old&#10;• every fact has provenance (source + confidence + ts)&#10;• L1 token budget bounded — when warm exceeds 600 tokens, lowest-priority keys drop&#10;• retrieval cost paid only when needed; never per turn" style="rounded=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1420" y="860" width="660" height="200" as="geometry" />
        </mxCell>
        <mxCell id="back" value="BACKUP&#10;PG: managed point-in-time recovery (Supabase) or pg_dump nightly&#10;LanceDB: lance is append-only with auto-versions; rsync data dir is a valid backup" style="rounded=1;fillColor=#F8FAFC;strokeColor=#64748B;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1420" y="1080" width="660" height="120" as="geometry" />
        </mxCell>
        <mxCell id="we1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C2410C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="w1" target="set">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="we2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C2410C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="w2" target="set">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="we3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C2410C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="w3" target="set">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="we4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C2410C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="w4" target="set">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="we5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2563EB;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="set" target="pg_facts">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="we6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#BE123C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="set" target="lance_idx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="we7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#4338CA;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="pg_facts" target="l1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p10" name="10 Interrupt &amp; Speech control">
    <mxGraphModel dx="2200" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" value="INTERRUPT &amp; SPEECH STATE MACHINE" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="The ONLY thing an interrupt cancels is speech (and the directive buffer being filled MID-stream). Background tasks stay alive." style="text;html=1;fontSize=12;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="56" width="1900" height="22" as="geometry" />
        </mxCell>
        <mxCell id="sm" value="STATE MACHINE (interrupt.py)" style="rounded=1;fillColor=#E8F5E9;strokeColor=#16A34A;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="700" height="600" as="geometry" />
        </mxCell>
        <mxCell id="st_idle" value="IDLE" style="ellipse;fillColor=#BBF7D0;strokeColor=#16A34A;fontStyle=1;fontSize=12;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="120" y="180" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="st_listen" value="LISTENING" style="ellipse;fillColor=#FEF08A;strokeColor=#CA8A04;fontStyle=1;fontSize=12;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="320" y="180" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="st_think" value="THINKING" style="ellipse;fillColor=#FDBA74;strokeColor=#9A3412;fontStyle=1;fontSize=12;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="540" y="180" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="st_speak" value="SPEAKING" style="ellipse;fillColor=#99F6E4;strokeColor=#0F766E;fontStyle=1;fontSize=12;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="320" y="320" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="st_wait_user" value="WAIT_USER&#10;(NEEDS_INFO surfaced)" style="ellipse;fillColor=#E9D5FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="540" y="320" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="st_int" value="any state -&gt; LISTENING&#10;on interrupt event" style="rounded=1;fillColor=#FECACA;strokeColor=#DC2626;fontStyle=1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="120" y="460" width="600" height="60" as="geometry" />
        </mxCell>
        <mxCell id="st_e1" value="user voice / chat" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#16A34A;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="st_idle" target="st_listen">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="st_e2" value="audio_end" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CA8A04;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="st_listen" target="st_think">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="st_e3" value="first TTS frame" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9A3412;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="st_think" target="st_speak">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="st_e4" value="last frame" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0F766E;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="st_speak" target="st_idle">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="st_e5" value="needs_info surfaced" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7C3AED;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="st_speak" target="st_wait_user">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="st_e6" value="user replies" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7C3AED;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="st_wait_user" target="st_listen">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="i_src" value="INTERRUPT SOURCES" style="rounded=1;fillColor=#FFF7ED;strokeColor=#C2410C;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="730" width="700" height="600" as="geometry" />
        </mxCell>
        <mxCell id="is1" value="A) Wake word said again&#10;client sends interrupt {source: 'wake'}" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="790" width="660" height="70" as="geometry" />
        </mxCell>
        <mxCell id="is2" value="B) User starts speaking while AI is speaking&#10;client local VAD fires within 150ms&#10;client sends interrupt {source: 'voice'} (replace policy)" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="880" width="660" height="90" as="geometry" />
        </mxCell>
        <mxCell id="is3" value="C) Stop button on UI&#10;interrupt {source: 'button'} (stop only, do not start listening)" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="990" width="660" height="80" as="geometry" />
        </mxCell>
        <mxCell id="is4" value="D) Server-side anti-self-trigger (Phase 3 step 14)&#10;if wake-word fires WHILE TTS is playing AND mic level &lt; threshold,&#10;ignore (likely picked up its own audio through speakers without AEC)" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="1090" width="660" height="100" as="geometry" />
        </mxCell>
        <mxCell id="is5" value="E) Typed message during TTS&#10;default policy = QUEUE (deliver after current sentence)&#10;user UI can override to REPLACE" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="1210" width="660" height="100" as="geometry" />
        </mxCell>
        <mxCell id="seq" value="WHAT HAPPENS WHEN INTERRUPT FIRES" style="rounded=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="780" y="100" width="1380" height="1230" as="geometry" />
        </mxCell>
        <mxCell id="seq1" value="1) Cancel SPEAKING coroutine (cancel_scope.cancel())&#10;TTS generator stops emitting; outbound audio stream ends." style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="800" y="160" width="1340" height="80" as="geometry" />
        </mxCell>
        <mxCell id="seq2" value="2) Cancel ENGINE inference for slot 0 (Main only)&#10;Sub-agent slots are NOT cancelled. They keep running.&#10;HTTP DELETE /completion?id=K (llama.cpp supports per-id cancel)." style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="800" y="260" width="1340" height="100" as="geometry" />
        </mxCell>
        <mxCell id="seq3" value="3) DISCARD directive buffer&#10;If [DELEGATE … was being assembled mid-stream, throw it away.&#10;Prevents ghost sub-agents being spawned from half-formed commands." style="rounded=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="800" y="380" width="1340" height="100" as="geometry" />
        </mxCell>
        <mxCell id="seq4" value="4) Append synthetic system note to history&#10;[INTERRUPTED at sentence i, AI was about to say: &quot;…&quot;]&#10;so the next turn knows context wasn't fully delivered." style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="800" y="500" width="1340" height="100" as="geometry" />
        </mxCell>
        <mxCell id="seq5" value="5) Switch FSM to LISTENING (or IDLE if source=='button')&#10;client opens mic immediately on the same intent (low-latency)" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="800" y="620" width="1340" height="100" as="geometry" />
        </mxCell>
        <mxCell id="seq6" value="6) Background tasks status&#10;ALL sub-agents continue. ALL summarizer jobs continue.&#10;Their reports keep flowing into signal bus.&#10;The proactive notifier may surface them once user is silent again." style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontStyle=1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="800" y="740" width="1340" height="120" as="geometry" />
        </mxCell>
        <mxCell id="seq7" value="7) 'stop the task too' intent&#10;If user explicitly says 'stop everything' / 'cancel that',&#10;Main will write [STOP_TASK task_id=…] in its next reply.&#10;Orchestrator then cancels the sub-agent + frees its slot." style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="800" y="880" width="1340" height="120" as="geometry" />
        </mxCell>
        <mxCell id="seq8" value="LATENCY GUARANTEE&#10;wake-word interrupt to TTS-silence ≤ 100ms&#10;voice interrupt (VAD) to TTS-silence ≤ 200ms&#10;achieved by always running outbound_loop on the same event loop and using cancel_scope" style="rounded=1;fillColor=#FEF08A;strokeColor=#CA8A04;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="800" y="1020" width="1340" height="160" as="geometry" />
        </mxCell>
        <mxCell id="seq_e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2563EB;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="seq1" target="seq2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="seq_e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#DC2626;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="seq2" target="seq3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="seq_e3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2563EB;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="seq3" target="seq4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="seq_e4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2563EB;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="seq4" target="seq5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="seq_e5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#16A34A;dashed=1;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="seq5" target="seq6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="seq_e6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C2410C;dashed=1;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="seq6" target="seq7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p11" name="11 Proactive Notifier">
    <mxGraphModel dx="2200" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" value="PROACTIVE NOTIFIER (background, surfaces DONE/NEEDS_INFO without user prompt)" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1700" height="30" as="geometry" />
        </mxCell>
        <mxCell id="loop" value="BACKGROUND LOOP (every 2s)" style="rounded=1;fillColor=#E8F5E9;strokeColor=#16A34A;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="650" height="1240" as="geometry" />
        </mxCell>
        <mxCell id="lp1" value="1) tick" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="610" height="40" as="geometry" />
        </mxCell>
        <mxCell id="lp2" value="2) for each active session, peek signal_bus&#10;collect fresh DONE / NEEDS_INFO / ERROR (ignore STEP)" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="610" height="80" as="geometry" />
        </mxCell>
        <mxCell id="lp3" value="3) batch by task_id; condense same-task signals" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="320" width="610" height="60" as="geometry" />
        </mxCell>
        <mxCell id="g_speak" value="GATE A&#10;is_ai_speaking?&#10;is user mid-utterance?" style="rhombus;fillColor=#FEF08A;strokeColor=#CA8A04;fontSize=11;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="160" y="410" width="430" height="100" as="geometry" />
        </mxCell>
        <mxCell id="g_speak_y" value="YES -&gt; defer&#10;wait for window to open" style="rounded=1;fillColor=#FDE68A;strokeColor=#CA8A04;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="540" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="g_deb" value="GATE B&#10;debounce: last proactive sent &gt; 30s ago?&#10;respect do_not_disturb window?" style="rhombus;fillColor=#FEF08A;strokeColor=#CA8A04;fontSize=11;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="160" y="630" width="430" height="100" as="geometry" />
        </mxCell>
        <mxCell id="g_deb_n" value="NO -&gt; keep queued, retry next tick" style="rounded=1;fillColor=#FDE68A;strokeColor=#CA8A04;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="770" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="g_imp" value="GATE C&#10;importance score &gt;= threshold?&#10;(NEEDS_INFO=1.0, DONE for user-initiated task=0.8, DONE for self-initiated=0.4)" style="rhombus;fillColor=#FEF08A;strokeColor=#CA8A04;fontSize=11;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="160" y="850" width="430" height="120" as="geometry" />
        </mxCell>
        <mxCell id="g_imp_n" value="NO -&gt; just write event{kind:'task_done'}&#10;no synthetic turn (UI feed only)" style="rounded=1;fillColor=#FDE68A;strokeColor=#CA8A04;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="990" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ok" value="ALL GATES PASS -&gt; proceed" style="rounded=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontStyle=1;fontSize=12;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="160" y="1100" width="430" height="60" as="geometry" />
        </mxCell>
        <mxCell id="run" value="4) build synthetic turn input&#10;{kind: 'proactive', task_id, signals: [...], respond_via: 'chat_only'}&#10;Supervisor.handle_turn(this) -&gt; same as page 4/5" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="1180" width="610" height="120" as="geometry" />
        </mxCell>
        <mxCell id="re_speak" value="OPTIONAL VOICE&#10;If user pref allow_proactive_voice=true AND device idle &gt; 5s,&#10;respond_via='voice+chat'." style="rounded=1;fillColor=#FED7AA;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="730" y="160" width="700" height="100" as="geometry" />
        </mxCell>
        <mxCell id="output" value="OUTPUT (client side)&#10;chat bubble + activity feed entry + (optional) TTS prompt&#10;mobile/web push notification if app backgrounded&#10;(pushed via Server 1 push pipeline using stored device tokens)" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="730" y="280" width="700" height="140" as="geometry" />
        </mxCell>
        <mxCell id="mute" value="USER CONTROLS (settings)&#10;• allow_proactive: bool&#10;• allow_proactive_voice: bool&#10;• do_not_disturb_windows: list[(start,end)]&#10;• importance_threshold: float (default 0.7)" style="rounded=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="730" y="440" width="700" height="160" as="geometry" />
        </mxCell>
        <mxCell id="ex" value="EXAMPLES" style="rounded=1;fillColor=#FFF7ED;strokeColor=#C2410C;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1450" y="100" width="700" height="900" as="geometry" />
        </mxCell>
        <mxCell id="ex1" value="EXAMPLE 1 — research task DONE while user is silent&#10;event{tool_done} fires immediately&#10;Main synth-turn: 'Quick update — I've finished the vendor compare. Want the summary?'" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1470" y="160" width="660" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ex2" value="EXAMPLE 2 — sub-agent NEEDS_INFO&#10;Main synth-turn: 'One question to keep going on the email draft — what tone do you want?'&#10;FSM goes WAIT_USER until user replies." style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1470" y="300" width="660" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ex3" value="EXAMPLE 3 — meeting summary ready (after meeting mode ends)&#10;Main synth-turn: 'Saved your meeting summary and 3 action items. Want me to schedule reminders?'" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1470" y="440" width="660" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ex4" value="EXAMPLE 4 — client app backgrounded&#10;notifier proceeds, but emits a push notification via Server 1 instead of synth turn.&#10;Reopen app -&gt; client reattaches session, sees pending NEEDS_INFO and opens it." style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1470" y="580" width="660" height="140" as="geometry" />
        </mxCell>
        <mxCell id="ex5" value="EXAMPLE 5 — interrupt during proactive&#10;User cuts in -&gt; proactive turn aborts (page 10 rules)&#10;Pending signals stay queued; will retry on next idle window." style="rounded=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1470" y="740" width="660" height="120" as="geometry" />
        </mxCell>
        <mxCell id="le1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#16A34A;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="lp1" target="lp2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="le2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#16A34A;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="lp2" target="lp3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="le3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CA8A04;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="lp3" target="g_speak">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="le4" value="YES" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CA8A04;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="g_speak" target="g_speak_y">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="le5" value="NO" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CA8A04;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="g_speak" target="g_deb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="le6" value="NO" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CA8A04;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="g_deb" target="g_deb_n">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="le7" value="YES" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CA8A04;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="g_deb" target="g_imp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="le8" value="NO" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CA8A04;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="g_imp" target="g_imp_n">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="le9" value="YES" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#16A34A;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="g_imp" target="ok">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="le10" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#16A34A;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="ok" target="run">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="le11" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2563EB;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="run" target="output">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p12" name="12 Meeting + Long-input">
    <mxGraphModel dx="2200" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" value="MEETING MODE  &amp;  LONG-INPUT MODE" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>
        <mxCell id="meet" value="MEETING MODE" style="rounded=1;fillColor=#FFF7ED;strokeColor=#C2410C;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="1040" height="1240" as="geometry" />
        </mxCell>
        <mxCell id="m1" value="user: 'start meeting mode' / 'record this meeting'&#10;client sends mode {mode: 'meeting'}" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="1000" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m2" value="Supervisor.set_mode('meeting')&#10;• disables Main inference per utterance (no per-sentence LLM call)&#10;• keeps STT streaming continuously&#10;• emits caption events but no audio reply&#10;• creates a meeting record in PG (id, started_at)" style="rounded=1;fillColor=#FDBA74;strokeColor=#9A3412;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="260" width="1000" height="120" as="geometry" />
        </mxCell>
        <mxCell id="m3" value="STT stream -&gt; diarization (pyannote-style identification, stub in Phase 1, real in Phase 3)&#10;chunk every 30s -&gt; LanceDB meeting_chunks (speaker, ts, text, embedding)" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="400" width="1000" height="100" as="geometry" />
        </mxCell>
        <mxCell id="m4" value="DURING the meeting:&#10;• 'Hey Vayumi, …' -&gt; full turn pipeline runs (Main reads recent transcript chunks as context)&#10;• '…until next time you're addressed' rule prevents talking unprompted&#10;• meetings can run for hours — KV cache is irrelevant because Main is dormant" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="520" width="1000" height="140" as="geometry" />
        </mxCell>
        <mxCell id="m5" value="user: 'end meeting mode' -&gt; Supervisor.set_mode('conversation')" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="680" width="1000" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m6" value="POST-MEETING PIPELINE (P2 sub-agent)&#10;1) summarize transcript (research-style sub-agent)&#10;2) extract action items (productivity sub-agent)&#10;3) memory.facts.set(meeting:&lt;date&gt;:summary, ...)&#10;4) optional: schedule reminders, send updates (comms sub-agent if user opts in)" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="760" width="1000" height="160" as="geometry" />
        </mxCell>
        <mxCell id="m7" value="Proactive notifier surfaces:&#10;'Saved your meeting summary and N action items. Want me to schedule reminders?'" style="rounded=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="940" width="1000" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m8" value="Later query example&#10;User: 'what did we decide about the migration last Tuesday?'&#10;Main writes [RECALL meeting:2026-05-05]&#10;orchestrator queries LanceDB meeting_chunks + facts -&gt; result fed back" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="1040" width="1000" height="140" as="geometry" />
        </mxCell>
        <mxCell id="m_rule" value="Cost-of-meeting RULE&#10;During meeting, Main does ZERO inference unless addressed.&#10;TTS is silent. No KV pressure. Diarization + storage only." style="rounded=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="1200" width="1000" height="120" as="geometry" />
        </mxCell>
        <mxCell id="long" value="LONG-INPUT MODE (paste / dictate / attach big doc)" style="rounded=1;fillColor=#F5F3FF;strokeColor=#7C3AED;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1100" y="100" width="1060" height="1240" as="geometry" />
        </mxCell>
        <mxCell id="lg1" value="Trigger: input token estimate &gt; 6000 tokens&#10;(or attachment size &gt; 200KB)" style="rounded=1;fillColor=#F3E8FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1120" y="160" width="1020" height="80" as="geometry" />
        </mxCell>
        <mxCell id="lg2" value="IMMEDIATE ack (within 300ms)&#10;Main writes: 'Got it — processing this in chunks, will surface key points as I go.'&#10;(this is a non-LLM template response, not a model call)" style="rounded=1;fillColor=#E9D5FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1120" y="260" width="1020" height="100" as="geometry" />
        </mxCell>
        <mxCell id="lg3" value="Background:&#10;[DELEGATE capability=research goal='summarize doc' payload={text|url}]&#10;sub-agent does:&#10;1) chunk (sentence + paragraph aware), e.g. 1500 tokens each&#10;2) per-chunk summary in parallel (P1 across slots)&#10;3) merge into hierarchical outline" style="rounded=1;fillColor=#F3E8FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1120" y="380" width="1020" height="160" as="geometry" />
        </mxCell>
        <mxCell id="lg4" value="STEP signals stream the running outline&#10;event{kind:'task_step', summary:'processed 3/8 chunks…'}&#10;client renders progress bar in activity feed" style="rounded=1;fillColor=#F3E8FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1120" y="560" width="1020" height="100" as="geometry" />
        </mxCell>
        <mxCell id="lg5" value="DONE -&gt; final answer feeds Main&#10;Main turns it into a streaming reply (chat or voice depending on input)" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1120" y="680" width="1020" height="100" as="geometry" />
        </mxCell>
        <mxCell id="lg6" value="Side effect&#10;chunks stored in LanceDB doc_chunks under doc_id&#10;future questions about the doc use [RECALL doc:&lt;doc_id&gt;]&#10;no need to re-paste the doc" style="rounded=1;fillColor=#F3E8FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1120" y="800" width="1020" height="120" as="geometry" />
        </mxCell>
        <mxCell id="lg7" value="EMERGENCY GUARD&#10;If projected ctx + chunk-summaries &gt; 28k tokens during merge:&#10;• keep recent N raw chunks + the running outline&#10;• drop oldest chunks (already in LanceDB)&#10;• never block UX with mid-flight compression" style="rounded=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1120" y="940" width="1020" height="160" as="geometry" />
        </mxCell>
        <mxCell id="lg8" value="ATTACHMENT INPUTS&#10;image -&gt; OCR (Phase 3) -&gt; treated as pasted text&#10;audio -&gt; STT -&gt; treated as pasted text&#10;video -&gt; sample N frames + STT audio -&gt; treated as pasted text + image set" style="rounded=1;fillColor=#FFF7ED;strokeColor=#C2410C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1120" y="1120" width="1020" height="160" as="geometry" />
        </mxCell>
        <mxCell id="me1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#EA580C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="m1" target="m2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="me2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9A3412;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="m2" target="m3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="me3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#EA580C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="m3" target="m4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="me4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#EA580C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="m4" target="m5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="me5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#16A34A;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="m5" target="m6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="me6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#16A34A;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="m6" target="m7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="me7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#EA580C;dashed=1;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="m7" target="m8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lge1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7C3AED;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="lg1" target="lg2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lge2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7C3AED;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="lg2" target="lg3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lge3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7C3AED;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="lg3" target="lg4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lge4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7C3AED;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="lg4" target="lg5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lge5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7C3AED;dashed=1;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="lg5" target="lg6">
          <mxGeometry relative="1" as="geometry" />
