        <mxCell id="lane_o" value="ORCHESTRATOR" style="rounded=1;fillColor=#FFF7ED;strokeColor=#C2410C;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=12;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1090" y="100" width="380" height="1300" as="geometry" />
