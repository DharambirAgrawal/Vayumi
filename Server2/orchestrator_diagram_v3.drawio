  <diagram id="p02" name="02 Boot Sequence">
    <mxGraphModel dx="2200" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" value="BOOT SEQUENCE (server start to ready)" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="If any step fails, server REFUSES TO START. No silent fallbacks." style="text;html=1;fontSize=12;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="56" width="900" height="22" as="geometry" />
        </mxCell>
        <mxCell id="b0" value="0. uvicorn loads server.app:app" style="rounded=1;fillColor=#E0F2FE;strokeColor=#0369A1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="110" width="380" height="60" as="geometry" />
        </mxCell>
        <mxCell id="b1" value="1. Settings()  validate every env var (pydantic-settings)&#10;APP_ENV, JWT_PUBLIC_KEY, DATABASE_URL, REDIS_URL, LANCEDB_DIR,&#10;LLAMA_*, STT_*, KOKORO_*, BGE_*, GROQ_API_KEY, TAVILY_API_KEY?, MCP_SERVERS_JSON?" style="rounded=1;fillColor=#FEF08A;strokeColor=#CA8A04;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="200" width="700" height="100" as="geometry" />
        </mxCell>
        <mxCell id="b2" value="2. Postgres pool (asyncpg)&#10;run schema.sql (idempotent CREATE TABLE IF NOT EXISTS)&#10;migration history table tracks applied files" style="rounded=1;fillColor=#C7D2FE;strokeColor=#4338CA;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="330" width="700" height="100" as="geometry" />
        </mxCell>
        <mxCell id="b3" value="3. Redis (own + Server-1 shared)&#10;PING both. Subscribe to signal-bus channel for this instance." style="rounded=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="460" width="700" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b4" value="4. LanceDB&#10;connect(LANCEDB_DIR)&#10;ensure tables: facts_index, session_history, meeting_chunks, doc_chunks" style="rounded=1;fillColor=#FECDD3;strokeColor=#BE123C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="570" width="700" height="100" as="geometry" />
        </mxCell>
        <mxCell id="b5" value="5. Embedder (bge-small-en-v1.5 ONNX)&#10;load once, expose .encode(text) -&gt; np.ndarray" style="rounded=1;fillColor=#DDD6FE;strokeColor=#6D28D9;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="700" width="700" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b6" value="6. llama-server subprocess&#10;./bin/llama-server -m gemma-3n-e2b-it-q4_k_m.gguf&#10;--port 8081 -np 4 --ctx-size 32768 --slot-prompt-similarity 0.5&#10;wait until /health -&gt; ok" style="rounded=1;fillColor=#FDBA74;strokeColor=#9A3412;fontSize=11;fontColor=#111827;fontStyle=1;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="810" width="700" height="120" as="geometry" />
        </mxCell>
        <mxCell id="b7" value="7. Engine pool warmup&#10;send a 2-token completion to each slot to allocate KV cache" style="rounded=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="960" width="700" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b8" value="8. Kokoro TTS  + Silero VAD&#10;load ONNX models, preallocate buffers" style="rounded=1;fillColor=#CCFBF1;strokeColor=#0F766E;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="1070" width="700" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b9" value="9. Tool registry&#10;import tools/* + load MCP servers from MCP_SERVERS_JSON&#10;mirror their tools, subscribe to tools_changed notifications" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="1180" width="700" height="100" as="geometry" />
        </mxCell>
        <mxCell id="b10" value="10. Background tasks start&#10;• proactive notifier loop (3s tick)&#10;• summarizer worker (P2 consumer)&#10;• signal bus drainer&#10;• MCP tool-list refresh listener" style="rounded=1;fillColor=#E9D5FF;strokeColor=#7C3AED;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="900" y="200" width="700" height="120" as="geometry" />
        </mxCell>
        <mxCell id="b11" value="11. Mount routes&#10;GET / (web client static) · GET /healthz · WS /ws/v1/session" style="rounded=1;fillColor=#99F6E4;strokeColor=#0F766E;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="900" y="350" width="700" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b12" value="12. Server READY&#10;write server_health.last_boot=now()&#10;log structured READY event" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontStyle=1;fontSize=12;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="900" y="460" width="700" height="100" as="geometry" />
        </mxCell>
        <mxCell id="fail" value="ANY failure between step 1 and step 11 -&gt; raise, log, exit code 1.&#10;Container/process supervisor restarts. We never run in a degraded state." style="rounded=1;fillColor=#FEE2E2;strokeColor=#B91C1C;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="900" y="600" width="700" height="100" as="geometry" />
        </mxCell>
        <mxCell id="shut" value="Graceful shutdown (reverse order)&#10;close WS sessions -&gt; stop notifier -&gt; flush summarizer -&gt; kill llama-server -&gt; close Redis/Postgres/LanceDB" style="rounded=1;fillColor=#F1F5F9;strokeColor=#64748B;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="900" y="730" width="700" height="100" as="geometry" />
        </mxCell>
        <mxCell id="be1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0369A1;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b0" target="b1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="be2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CA8A04;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b1" target="b2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="be3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#4338CA;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b2" target="b3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="be4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#DC2626;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b3" target="b4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="be5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#BE123C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b4" target="b5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="be6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6D28D9;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b5" target="b6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="be7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9A3412;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b6" target="b7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="be8" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#D97706;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b7" target="b8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="be9" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0F766E;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b8" target="b9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="be10" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#EA580C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b9" target="b10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="be11" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7C3AED;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b10" target="b11">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="be12" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0F766E;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b11" target="b12">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p03" name="03 Connection &amp; Auth">
    <mxGraphModel dx="2200" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" value="CLIENT CONNECT &amp; AUTH HANDSHAKE" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>
        <mxCell id="lc" value="CLIENT" style="rounded=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="500" height="1200" as="geometry" />
        </mxCell>
        <mxCell id="lt" value="TRANSPORT (ws.py)" style="rounded=1;fillColor=#F5F3FF;strokeColor=#6D28D9;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="580" y="80" width="540" height="1200" as="geometry" />
        </mxCell>
        <mxCell id="la" value="AUTH (auth.py)" style="rounded=1;fillColor=#FFE4E6;strokeColor=#BE123C;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1160" y="80" width="500" height="1200" as="geometry" />
        </mxCell>
        <mxCell id="lo" value="ORCHESTRATOR (Supervisor per session)" style="rounded=1;fillColor=#FFF7ED;strokeColor=#C2410C;strokeWidth=2;verticalAlign=top;spacingTop=8;fontStyle=1;fontSize=13;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1700" y="80" width="460" height="1200" as="geometry" />
        </mxCell>
        <mxCell id="c1" value="1) Get JWT from Server 1 login&#10;(stored in OS keychain on app, sessionStorage on web)" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="460" height="70" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="2) WebSocket(`/ws/v1/session?token=&lt;jwt&gt;`)" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="250" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="3) On open -&gt; send hello&#10;{ client, capabilities: {aec, vad, wake}, session_id? }" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="330" width="460" height="70" as="geometry" />
        </mxCell>
        <mxCell id="c4" value="4) Receive welcome { session_id, server_version }&#10;UI shows 'connected'" style="rounded=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="900" width="460" height="70" as="geometry" />
        </mxCell>
        <mxCell id="c5" value="5) Heartbeat: ping every 15s, expect pong&#10;3 missed pongs -&gt; reconnect with backoff" style="rounded=1;fillColor=#E0F2FE;strokeColor=#0369A1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="990" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="c6" value="6) Reconnect rules&#10;same session_id sent in hello -&gt; server reattaches Supervisor&#10;active tasks survive a brief disconnect" style="rounded=1;fillColor=#E0F2FE;strokeColor=#0369A1;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="1090" width="460" height="100" as="geometry" />
        </mxCell>
        <mxCell id="t1" value="A) ws.handshake&#10;extract token from query string" style="rounded=1;fillColor=#DDD6FE;strokeColor=#6D28D9;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="250" width="500" height="70" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="B) call auth.verify_token(token)" style="rounded=1;fillColor=#DDD6FE;strokeColor=#6D28D9;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="340" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="C) on fail -&gt; close(4401, reason)" style="rounded=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="420" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="t4" value="D) on success -&gt; await ws.accept()&#10;create Supervisor(user_id, session_id)&#10;register in active_sessions[user_id][session_id]" style="rounded=1;fillColor=#DDD6FE;strokeColor=#6D28D9;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="500" width="500" height="100" as="geometry" />
        </mxCell>
        <mxCell id="t5" value="E) await first message; must be hello&#10;mismatch -&gt; close(4400)" style="rounded=1;fillColor=#DDD6FE;strokeColor=#6D28D9;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="620" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t6" value="F) write welcome event&#10;start TaskGroup: inbound_loop, outbound_loop, supervisor_run" style="rounded=1;fillColor=#DDD6FE;strokeColor=#6D28D9;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="720" width="500" height="100" as="geometry" />
        </mxCell>
        <mxCell id="t7" value="G) inbound_loop&#10;dispatch JSON  -&gt; supervisor.on_message&#10;dispatch binary -&gt; supervisor.on_audio_chunk" style="rounded=1;fillColor=#DDD6FE;strokeColor=#6D28D9;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="840" width="500" height="100" as="geometry" />
        </mxCell>
        <mxCell id="t8" value="H) outbound_loop&#10;reads supervisor.outgoing queue -&gt; ws.send" style="rounded=1;fillColor=#DDD6FE;strokeColor=#6D28D9;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="960" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t9" value="I) on disconnect -&gt; cancel TaskGroup&#10;Supervisor.flush_to_disk(); keep alive 60s for reconnect" style="rounded=1;fillColor=#DDD6FE;strokeColor=#6D28D9;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="1060" width="500" height="100" as="geometry" />
        </mxCell>
        <mxCell id="a1" value="verify_token(token)" style="rounded=1;fillColor=#FECDD3;strokeColor=#BE123C;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1180" y="160" width="460" height="50" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="1) jose.jwt.decode(token, JWT_PUBLIC_KEY, RS256)&#10;validates signature, exp, iat, required claims" style="rounded=1;fillColor=#FDA4AF;strokeColor=#BE123C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1180" y="230" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a3" value="2) Redis GET blocklist:&lt;jti&gt; on Server-1 Redis&#10;hit -&gt; raise AuthError" style="rounded=1;fillColor=#FDA4AF;strokeColor=#BE123C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1180" y="330" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a4" value="3) return TokenPayload&#10;{ user_id, session_id, jti, device_type, scopes, exp }" style="rounded=1;fillColor=#FDA4AF;strokeColor=#BE123C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1180" y="430" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a5" value="4) cache decoded payload in process LRU for 60s&#10;(reconnect storm protection)" style="rounded=1;fillColor=#FEF3C7;strokeColor=#CA8A04;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1180" y="530" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a6" value="5) Token expiry while connected&#10;exp - now &lt; 5 min -&gt; emit event{kind:'token_expiring'}&#10;client refreshes against Server 1 and reconnects" style="rounded=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1180" y="630" width="460" height="100" as="geometry" />
        </mxCell>
        <mxCell id="o1" value="Supervisor.__init__(user_id, session_id)" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontStyle=1;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1720" y="160" width="420" height="60" as="geometry" />
        </mxCell>
        <mxCell id="o2" value="• load Session row from PG (or create)&#10;• load warm profile (memory.warm.build())&#10;• create empty TaskBoard&#10;• create asyncio queues: incoming, outgoing, signals&#10;• allocate llama slot 0 (sticky)&#10;• subscribe to Redis signal-bus channel for this session" style="rounded=1;fillColor=#FDBA74;strokeColor=#9A3412;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1720" y="240" width="420" height="180" as="geometry" />
        </mxCell>
        <mxCell id="o3" value="state machine: IDLE -&gt; LISTENING -&gt; THINKING -&gt; SPEAKING -&gt; IDLE&#10;interrupt -&gt; jump to LISTENING from any state" style="rounded=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1720" y="440" width="420" height="100" as="geometry" />
        </mxCell>
        <mxCell id="o4" value="on disconnect&#10;persist conversation, mark sessions.last_seen=now()&#10;LIVE TASKS keep running (sub-agents are independent)" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=11;fontColor=#111827;whiteSpace=wrap;html=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1720" y="560" width="420" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ec1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2563EB;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="c1" target="c2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2563EB;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="c2" target="t1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="et1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6D28D9;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="t1" target="t2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="et2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#BE123C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="t2" target="a1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ea1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#BE123C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="a1" target="a2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ea2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#BE123C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="a2" target="a3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ea3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#BE123C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="a3" target="a4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ea4" value="OK" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#388E3C;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="a4" target="t4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ea5" value="FAIL" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#DC2626;endArrow=block;endFill=1;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;fontSize=11;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="a4" target="t3">
